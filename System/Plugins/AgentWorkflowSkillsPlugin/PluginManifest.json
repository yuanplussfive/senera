{
  "Plugin": {
    "Name": "AgentWorkflowSkillsPlugin",
    "Title": "工作流技能",
    "Version": "0.1.0",
    "Kind": "Skill",
    "Description": "提供面向模型的可复用工作流技能，指导复杂任务的检索、取证、验证和输出。"
  },
  "Discovery": {
    "Tags": [
      "skill",
      "workflow",
      "技能",
      "工作流",
      "调查",
      "审查",
      "记忆",
      "文档"
    ]
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 45
  },
  "Skills": [
    {
      "Name": "WorkspaceInvestigationSkill",
      "Title": "工作区调查",
      "DescriptionFile": "./docs/WorkspaceInvestigation.md",
      "RecommendedTools": [
        "AgentDelegateTool",
        "FastContextWorkspaceMapTool",
        "FastContextHybridSearchTool",
        "FastContextSearchTool",
        "FastContextSymbolSearchTool",
        "FastContextReadTool"
      ],
      "RecommendedAgents": [
        "WorkspaceExplorer",
        "SymbolTracer"
      ],
      "RecommendedWorkflows": [
        "WorkspaceInvestigationWorkflow"
      ],
      "Search": {
        "Summary": "定位代码、配置、提示词、UI 文案、错误处理或跨文件实现时，按搜索、读取、再搜索、取证的闭环工作。",
        "Keywords": [
          "workspace",
          "code",
          "search",
          "read",
          "investigate",
          "debug",
          "工作区",
          "代码",
          "检索",
          "读取",
          "定位",
          "调查",
          "排查",
          "project",
          "codebase",
          "repository",
          "repo",
          "README",
          "package",
          "项目",
          "用途",
          "代码库",
          "仓库",
          "说明",
          "入口",
          "结构"
        ],
        "Capabilities": [
          {
            "Id": "workflow.workspace-investigation",
            "Title": "Workspace investigation workflow",
            "Description": "Guide local code investigation through search, candidate reading, query refinement, and evidence-backed conclusions.",
            "Facets": {
              "Actions": [
                "investigate",
                "search",
                "read",
                "verify"
              ],
              "Targets": [
                "workspace",
                "source-code",
                "configuration",
                "prompt-template",
                "ui-code"
              ],
              "Inputs": [
                "natural-language",
                "identifier",
                "path",
                "error-text",
                "ui-description"
              ],
              "Outputs": [
                "source-location",
                "evidence-backed-summary",
                "next-edit-target"
              ],
              "Evidence": [
                "workspace-search-match",
                "workspace-read"
              ],
              "Effects": [
                "read-only",
                "index-cache"
              ]
            },
            "Aliases": [
              "代码调查",
              "搜索读取闭环",
              "find code and verify",
              "search read refine"
            ],
            "Examples": [
              "分析某个 UI 变化在哪里实现",
              "找模型输出 XML 修复逻辑",
              "where is streaming preview buffered"
            ],
            "Avoid": [
              "用户只要常识性回答、无需检查工作区时不要激活"
            ],
            "Risk": {
              "SideEffect": "index-cache",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "用户问某段功能、错误、UI、配置或提示词在代码中怎么实现，且需要本地证据。",
          "搜索结果不确定，需要读取候选文件并根据 imports、符号、路径继续追踪。",
          "用户询问当前项目、代码库或仓库是做什么的、有什么用途、入口和主要模块时，需要读取本地项目证据。",
          "用户要求概览项目用途或框架作用时，先查看项目地图并读取 README、package、配置或入口文件。"
        ],
        "Examples": [
          "看看插件工作区索引，找代码是怎么写的",
          "为什么停止按钮有时候不生效，查一下逻辑",
          "分析 planner 上下文实际怎么构建",
          "看看我们的项目是干嘛的，有什么用",
          "这个代码库主要做什么",
          "读取 README 和 package 后总结项目用途"
        ],
        "Avoid": [
          "无需本地工作区事实的闲聊、解释或纯设计讨论。"
        ]
      },
      "EvidenceRequirements": [
        {
          "Need": "workspace read source-of-truth evidence",
          "Accepts": [
            "workspace read",
            "project identity",
            "project purpose",
            "implementation detail",
            "source behavior"
          ],
          "MinimumQuality": [
            "observed"
          ],
          "Minimum": 1,
          "Purpose": "本地工作区结论需要来自已读取的文件、目录读取或源码片段；项目地图和搜索候选只用于定位，不满足最终回答。"
        }
      ]
    },
    {
      "Name": "PullRequestReviewSkill",
      "Title": "变更审查",
      "DescriptionFile": "./docs/PullRequestReview.md",
