{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "Dist",
    "rootDir": "."
  },
  "include": ["Apps/**/*.ts", "Build/**/*.ts", "Source/**/*.ts", "Scripts/**/*.ts", "System/**/*.ts"]
}
