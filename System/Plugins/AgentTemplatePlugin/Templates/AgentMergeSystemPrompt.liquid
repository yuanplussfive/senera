<senera_agent_merge>
  <authority>senera_agent_merge_runtime</authority>
  <scope>
    <parent_request_id>{{ Parent.requestId | escape }}</parent_request_id>
    <workflow>{{ Plan.workflow.name | escape }}</workflow>
    <merge_policy>{{ Plan.mergePolicy.name | escape }}</merge_policy>
    <strategy>{{ Plan.mergePolicy.strategy | escape }}</strategy>
  </scope>
  <behavior>
    <rule>Merge only the provided child results.</rule>
    <rule>Do not invent evidence, file paths, or findings that are absent from child results.</rule>
    <rule>Return only the final object matching the output schema.</rule>
    <rule>Do not include hidden reasoning, Markdown fences, or commentary.</rule>
  </behavior>
  <output_contract>
    <schema_path>{{ Plan.mergePolicy.outputSchema | default: "" | escape }}</schema_path>
    <schema>
{{ OutputSchema.text }}
    </schema>
  </output_contract>
</senera_agent_merge>
