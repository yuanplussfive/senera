{
  "form": {
    "version": 1,
    "sections": [
      {
        "id": "models",
        "label": "模型",
        "description": "配置主模型、供应商端点和默认模型。",
        "icon": "brain-circuit",
        "fields": [
          {
            "path": ["DefaultModelProviderId"],
            "label": "默认模型",
            "description": "启动和未指定模型时使用的 ModelProviders[].Id。",
            "type": "string",
            "placeholder": "选择一个已启用模型"
          },
          {
            "path": ["ModelProviderEndpoints"],
            "label": "供应商端点",
            "description": "保存接口地址、密钥和额外请求头。模型配置通过供应商 ID 引用这里。",
            "type": "array",
            "itemType": "table",
            "addLabel": "添加供应商",
            "itemLabelPath": ["Id"],
            "defaultItem": {
              "Id": "",
              "Icon": "",
              "Enabled": true,
              "BaseUrl": "",
              "Headers": {}
            },
            "itemFields": [
              {
                "path": ["Enabled"],
                "label": "启用供应商",
                "type": "boolean",
                "required": false
              },
              {
                "path": ["Icon"],
                "label": "图标",
                "description": "供应商列表里显示的图标名称。",
                "type": "string",
                "placeholder": "选择图标",
                "required": false
              },
              {
                "path": ["Id"],
                "label": "供应商 ID",
                "description": "供模型、向量模型和学习模型引用。",
                "type": "string",
                "placeholder": "自定义唯一 ID",
                "minLength": 1
              },
              {
                "path": ["BaseUrl"],
                "label": "Base URL",
                "description": "供应商 API 地址，通常以 /v1 结尾。",
                "type": "string",
                "placeholder": "https://.../v1",
                "minLength": 1
              },
              {
                "path": ["ApiKey"],
                "label": "API Key",
                "description": "供应商访问密钥。",
                "type": "string",
                "secret": true,
                "placeholder": "sk-...",
                "required": false
              },
              {
                "path": ["ApiVersion"],
                "label": "API Version",
                "description": "需要版本参数的供应商可填写。",
                "type": "string",
                "placeholder": "2023-06-01",
                "required": false
              },
              {
                "path": ["Headers"],
                "label": "请求头",
                "description": "额外 HTTP 请求头，按键值保存。",
                "type": "record",
                "itemType": "string",
                "keyPlaceholder": "Header-Name",
                "valuePlaceholder": "value",
                "required": false
              }
            ]
          },
          {
            "path": ["ModelProviders"],
            "label": "模型列表",
            "description": "每个模型配置引用一个供应商端点，并声明请求协议、模型名和运行参数。",
            "type": "array",
            "itemType": "table",
            "addLabel": "添加模型",
            "itemLabelPath": ["Model"],
            "defaultItem": {
              "Id": "",
              "ProviderId": "",
              "Icon": "",
              "Capabilities": {
                "Chat": true,
                "Embedding": false,
                "Rerank": false,
                "Vision": false,
                "ImageOutput": false,
                "Reasoning": false,
                "DeveloperRole": false,
                "StreamingUsage": true
              },
              "ContextWindowTokens": -1,
              "MaxModelOutputTokens": -1,
              "Endpoint": "ChatCompletions",
              "Model": "",
              "Temperature": 0,
              "TimeoutSeconds": 480,
              "FirstTokenTimeoutSeconds": 240,
              "MaxRequestSeconds": -1,
              "MaxNetworkRetries": 1,
              "RetryBaseDelaySeconds": 0.25,
              "RetryMaxDelaySeconds": 10,
              "RetryAfterMaxDelaySeconds": 60,
              "Stream": true,
              "MaxOutputTokens": -1
            },
            "itemFields": [
              {
                "path": ["ProviderId"],
                "label": "供应商 ID",
                "description": "填写上方供应商端点中的供应商 ID。",
                "type": "string",
                "placeholder": "选择供应商",
                "minLength": 1
              },
              {
                "path": ["Icon"],
                "label": "图标",
                "description": "模型列表里显示的图标名称。",
                "type": "string",
                "placeholder": "选择图标",
                "required": false
              },
              {
                "path": ["Capabilities", "Chat"],
                "label": "对话",
                "type": "boolean",
                "required": false
              },
              {
                "path": ["Capabilities", "Embedding"],
                "label": "向量嵌入",
                "type": "boolean",
                "required": false
              },
              {
                "path": ["Capabilities", "Rerank"],
                "label": "重排序",
                "type": "boolean",
                "required": false
              },
              {
                "path": ["Capabilities", "Vision"],
                "label": "识图",
                "type": "boolean",
                "required": false
              },
              {
                "path": ["Capabilities", "ImageOutput"],
                "label": "图像输出",
                "type": "boolean",
                "required": false
              },
              {
                "path": ["Capabilities", "Reasoning"],
                "label": "推理",
                "type": "boolean",
                "required": false
              },
              {
                "path": ["Capabilities", "DeveloperRole"],
                "label": "Developer Role",
                "description": "供应商原生支持 OpenAI developer 消息角色时启用；关闭时自动降级为 system 指令。",
                "type": "boolean",
                "required": false
              },
              {
                "path": ["Capabilities", "StreamingUsage"],
                "label": "流式 Usage",
                "description": "供应商支持 stream_options.include_usage 时启用；不兼容的网关可关闭并使用本地 token 估算。",
                "type": "boolean",
                "required": false
              },
              {
                "path": ["ContextWindowTokens"],
                "label": "上下文窗口",
                "description": "-1 表示未知或不声明。",
                "type": "number",
                "min": -1,
                "step": 1,
                "required": false
              },
              {
                "path": ["MaxModelOutputTokens"],
                "label": "模型最大输出",
                "description": "-1 表示未知或不声明。",
                "type": "number",
                "min": -1,
                "step": 1,
                "required": false
              },
              {
                "path": ["Endpoint"],
                "label": "请求协议",
                "description": "选择模型请求使用的接口协议。",
                "type": "string",
                "options": ["ChatCompletions", "Responses", "ClaudeMessages", "GoogleGenerateContent"],
                "optionLabels": {
                  "ChatCompletions": "Chat Completions",
                  "Responses": "Responses",
                  "ClaudeMessages": "Claude Messages",
                  "GoogleGenerateContent": "Google Generate Content"
                }
              },
              {
                "path": ["Model"],
                "label": "模型名",
                "type": "string",
                "placeholder": "从供应商模型列表选择",
                "minLength": 1
              },
              {
                "path": ["Temperature"],
                "label": "温度",
                "description": "0 到 2，越高越发散。",
                "type": "number",
                "min": 0,
                "max": 2,
                "step": 0.1,
                "required": false
              },
              {
                "path": ["MaxOutputTokens"],
                "label": "最大输出 Tokens",
                "description": "-1 表示不发送限制字段。",
                "type": "number",
                "min": -1,
                "step": 1,
                "required": false
              },
              {
                "path": ["Stream"],
                "label": "流式输出",
                "type": "boolean",
                "required": false
              },
              {
                "path": ["TimeoutSeconds"],
                "label": "请求超时",
                "description": "单位秒。",
                "type": "number",
                "min": 1,
                "step": 1,
                "required": false
              },
              {
                "path": ["FirstTokenTimeoutSeconds"],
                "label": "首 token 超时",
                "description": "单位秒，-1 表示关闭该检查。",
                "type": "number",
                "min": -1,
                "step": 1,
                "required": false
              },
              {
                "path": ["MaxRequestSeconds"],
                "label": "最大请求时长",
                "description": "单位秒，-1 表示不限制。",
                "type": "number",
                "min": -1,
                "step": 1,
                "required": false
              },
              {
                "path": ["MaxNetworkRetries"],
                "label": "网络重试次数",
                "type": "number",
                "min": 0,
                "step": 1,
                "required": false
              },
              {
                "path": ["RetryBaseDelaySeconds"],
                "label": "重试基础等待",
                "description": "单位秒；指数退避从该值开始。",
                "type": "number",
                "min": 0.001,
                "step": 0.05,
                "required": false
              },
              {
                "path": ["RetryMaxDelaySeconds"],
                "label": "重试最大等待",
                "description": "单位秒；指数退避不会超过该值。",
                "type": "number",
                "min": 0.001,
                "step": 1,
                "required": false
              },
              {
                "path": ["RetryAfterMaxDelaySeconds"],
                "label": "Retry-After 最大等待",
                "description": "单位秒；限制供应商 Retry-After 响应要求的最长等待。",
                "type": "number",
                "min": 0.001,
                "step": 1,
                "required": false
              }
            ]
          },
          {
            "path": ["ModelGroups"],
            "label": "模型分组",
            "description": "模型列表里的可编辑自动分组规则。默认规则来自模型图标规则。",
            "type": "array",
            "itemType": "table",
            "addLabel": "添加分组",
            "itemLabelPath": ["Label"],
            "required": false,
            "defaultItem": {
              "Id": "",
              "Label": "",
              "Icon": "",
              "Strategies": [
                {
                  "Match": "prefix",
                  "Values": []
                }
              ]
            },
            "itemFields": [
              {
                "path": ["Id"],
                "label": "分组 ID",
                "type": "string",
                "placeholder": "唯一 ID",
                "minLength": 1
              },
              {
                "path": ["Label"],
                "label": "名称",
                "type": "string",
                "placeholder": "分组名称",
                "minLength": 1
              },
              {
                "path": ["Icon"],
                "label": "图标",
                "type": "string",
                "placeholder": "选择图标",
                "required": false
              },
              {
                "path": ["Strategies"],
                "label": "匹配策略",
                "type": "array",
                "itemType": "table",
                "addLabel": "添加策略",
                "required": false,
                "defaultItem": {
                  "Match": "prefix",
                  "Values": []
                },
                "itemFields": [
                  {
                    "path": ["Match"],
                    "label": "匹配方式",
                    "type": "string",
                    "options": ["prefix", "includes", "exact", "suffix"],
                    "optionLabels": {
                      "prefix": "前缀",
                      "includes": "包含",
                      "exact": "精确",
                      "suffix": "后缀"
                    }
                  },
                  {
                    "path": ["Values"],
                    "label": "匹配词",
                    "type": "array",
                    "itemType": "string",
                    "placeholder": "例如 claude-",
                    "required": false
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "runtime",
        "label": "运行",
        "description": "控制主循环、工具执行、服务端和持久化。",
        "icon": "sliders-horizontal",
        "fields": [
          {
            "path": ["AgentLoop", "LoadedTools"],
            "label": "工具加载策略",
            "description": "dynamic 表示按需发现工具，all 表示加载全部工具。",
            "type": "string",
            "options": ["dynamic", "all"],
            "optionLabels": {
              "dynamic": "按需发现",
              "all": "全部加载"
            },
            "required": false
          },
          {
            "path": ["AgentLoop", "RunSettlementTimeoutSeconds"],
            "label": "轮次取消结算超时",
            "description": "取消旧轮次后等待模型、审批、工具和 Pi 会话进入空闲状态的最长时间；超时后不会继续修改会话分支。",
            "type": "number",
            "min": 1,
            "max": 300,
            "step": 1,
            "required": false
          },
          {
            "path": ["AgentLoop", "PiSessions", "RootDir"],
            "label": "Pi 会话目录",
            "description": "Pi 原生 session tree 的持久化目录，支持相对工作区路径。",
            "type": "string",
            "placeholder": ".senera/pi-sessions",
            "required": false
          },
          {
            "path": ["AgentLoop", "PiSessions", "MaxCachedSessions"],
            "label": "Pi 热会话缓存数",
            "description": "同时保留的 Pi session tree 与 harness 数量上限；超出后按最近使用顺序释放空闲会话。设为 0 可禁用空闲缓存。",
            "type": "number",
            "min": 0,
            "step": 1,
            "required": false
          },
          {
            "path": ["AgentLoop", "PiSessions", "Compaction", "Enabled"],
            "label": "自动压缩会话",
            "description": "当 Pi 分支存在足够的可回收历史时生成结构化摘要；固定工具和系统上下文开销不会伪装成可压缩历史。",
            "type": "boolean",
            "required": false
          },
          {
            "path": ["AgentLoop", "PiSessions", "Compaction", "TriggerRatio"],
            "label": "压缩触发比例",
            "description": "相对于 PiProxy 有效上下文预算的分支历史触发水位；模型上报的完整请求压力会单独诊断。",
            "type": "number",
            "min": 0.5,
            "max": 0.95,
            "step": 0.05,
            "required": false
          },
          {
            "path": ["AgentLoop", "PiSessions", "Compaction", "TargetRatio"],
            "label": "压缩目标比例",
            "description": "压缩后保留的近期 Pi 分支历史目标水位，必须小于触发比例。",
            "type": "number",
            "min": 0.2,
            "max": 0.8,
            "step": 0.05,
            "required": false
          },
          {
            "path": ["AgentLoop", "PiSessions", "Compaction", "HardLimitRatio"],
            "label": "压缩硬上限",
            "description": "可压缩分支历史超过该水位后，压缩失败将阻止继续发送不完整历史；固定上下文开销不计入该硬上限。",
            "type": "number",
            "min": 0.6,
            "max": 1,
            "step": 0.05,
            "required": false
          },
          {
            "path": ["AgentLoop", "PiSessions", "Compaction", "SummaryMaxTokens"],
            "label": "摘要输出上限",
            "description": "专用 BAML 压缩摘要允许输出的最大 token 数。",
            "type": "number",
            "min": 512,
            "max": 32768,
            "step": 512,
            "required": false
          },
          {
            "path": ["AgentLoop", "PiSessions", "Compaction", "TimeoutSeconds"],
            "label": "压缩超时",
            "description": "单次自动压缩允许的最长时间，单位秒。",
            "type": "number",
            "min": 1,
            "step": 1,
            "required": false
          },
          {
            "path": ["AgentLoop", "PiSessions", "Compaction", "UnknownContextWindowTokens"],
            "label": "未知上下文窗口",
            "description": "模型未声明上下文窗口时用于预算和压缩判断的保守 token 数。",
            "type": "number",
            "min": 16384,
            "step": 1024,
            "required": false
          },
          {
            "path": ["AgentLoop", "PiSessions", "Compaction", "UnknownModelOutputTokens"],
            "label": "未知模型输出上限",
            "description": "模型未声明最大输出能力且未配置请求输出上限时使用的保守 token 数。",
            "type": "number",
            "min": 512,
            "max": 131072,
            "step": 512,
            "required": false
          },
          {
            "path": ["ToolExecution", "TimeoutSeconds"],
            "label": "工具超时",
            "description": "单次工具进程最长运行时间，单位秒。",
            "type": "number",
            "min": 1,
            "step": 1,
            "required": false
          },
          {
            "path": ["ToolExecution", "MaxStdoutBytes"],
            "label": "工具 stdout 上限",
            "type": "number",
            "min": 1,
            "step": 1024,
            "required": false
          },
          {
            "path": ["ToolExecution", "MaxStderrBytes"],
            "label": "工具 stderr 上限",
            "type": "number",
            "min": 1,
            "step": 1024,
            "required": false
          },
          {
            "path": ["ToolExecution", "Environment", "Inherit"],
            "label": "子进程环境继承",
            "description": "决定本地 shell、PTY 和长连接进程是否继承宿主环境变量。",
            "type": "string",
            "options": ["all", "none"],
            "required": false
          },
          {
            "path": ["ToolExecution", "Environment", "IncludeOnly"],
            "label": "环境变量白名单",
            "description": "非空时只允许这些变量进入本地子进程。",
            "type": "array",
            "itemType": "string",
            "placeholder": "PATH",
            "required": false
          },
          {
            "path": ["ToolExecution", "Environment", "Exclude"],
            "label": "排除环境变量",
            "description": "从继承或调用方提供的环境中删除指定变量。",
            "type": "array",
            "itemType": "string",
            "placeholder": "SECRET_NAME",
            "required": false
          },
          {
            "path": ["ToolExecution", "Environment", "Set"],
            "label": "固定环境变量",
            "description": "显式设置并覆盖传给本地子进程的环境变量。",
            "type": "record",
            "itemType": "string",
            "keyPlaceholder": "NAME",
            "valuePlaceholder": "value",
            "required": false
          },
          {
            "path": ["ToolExecution", "Resources", "MaxActive"],
            "label": "最大活动执行资源",
            "description": "同一工作区允许同时运行的后台执行资源数量。",
            "type": "number",
            "min": 1,
            "max": 1000,
            "step": 1,
            "required": false
          },
          {
            "path": ["ToolExecution", "Resources", "MaxBufferedBytes"],
            "label": "资源输出缓冲",
            "description": "每个后台资源在内存中保留的可恢复输出字节预算。",
            "type": "number",
            "min": 1024,
            "step": 1024,
            "required": false
          },
          {
            "path": ["ToolExecution", "Resources", "MaxInputBytes"],
            "label": "资源单次输入上限",
            "type": "number",
            "min": 1,
            "step": 1024,
            "required": false
          },
          {
            "path": ["ToolExecution", "Resources", "MaxWaitSeconds"],
            "label": "资源最长等待",
            "description": "单次增量等待调用的最大秒数。",
            "type": "number",
            "min": 1,
            "max": 300,
            "step": 1,
            "required": false
          },
          {
            "path": ["ToolExecution", "Resources", "IdleTtlSeconds"],
            "label": "活动资源空闲 TTL",
            "description": "无人访问的运行中资源在自动终止前保留的秒数。",
            "type": "number",
            "min": 1,
            "step": 1,
            "required": false
          },
          {
            "path": ["ToolExecution", "Resources", "TerminalTtlSeconds"],
            "label": "终态资源保留 TTL",
            "description": "已完成资源的输出和状态继续可恢复的秒数。",
            "type": "number",
            "min": 1,
            "step": 1,
            "required": false
          },
          {
            "path": ["ToolExecution", "Resources", "SweepIntervalSeconds"],
            "label": "资源清理间隔",
            "type": "number",
            "min": 1,
            "step": 1,
            "required": false
          },
          {
            "path": ["ToolExecution", "Resources", "TerminationGraceSeconds"],
            "label": "资源终止宽限期",
            "description": "terminate 升级为 kill 前等待的秒数。",
            "type": "number",
            "min": 1,
            "max": 60,
            "step": 1,
            "required": false
          },
          {
            "path": ["Server", "Host"],
            "label": "服务 Host",
            "type": "string",
            "placeholder": "127.0.0.1",
            "required": false
          },
          {
            "path": ["Server", "Port"],
            "label": "服务端口",
            "type": "number",
            "min": 1,
            "max": 65535,
            "step": 1,
            "required": false
          },
          {
            "path": ["Server", "HotReload"],
            "label": "热重载",
            "type": "boolean",
            "required": false
          },
          {
            "path": ["Server", "RequestMaxBytes"],
            "label": "请求体上限",
            "type": "number",
            "min": 1,
            "step": 1024,
            "required": false
          },
          {
            "path": ["Persistence", "Kind"],
            "label": "会话存储",
            "type": "string",
            "options": ["sqlite", "memory"],
            "optionLabels": {
              "sqlite": "SQLite",
              "memory": "内存"
            },
            "required": false
          },
          {
            "path": ["Persistence", "DatabasePath"],
            "label": "会话数据库",
            "type": "string",
            "placeholder": ".senera/senera.db",
            "required": false
          },
          {
            "path": ["ConfigStore", "Enabled"],
            "label": "配置数据库",
            "type": "boolean",
            "required": false
          },
          {
            "path": ["ConfigStore", "DatabasePath"],
            "label": "配置数据库路径",
            "type": "string",
            "placeholder": ".senera/Config.sqlite",
            "required": false
          },
          {
            "path": ["ConfigStore", "MirrorJson"],
            "label": "同步 JSON 镜像",
            "description": "保存数据库配置时同步写回 senera.config.json。",
            "type": "boolean",
            "required": false
          }
        ]
      },
      {
        "id": "planning",
        "label": "规划与学习",
        "description": "配置 BAML planner、工具学习和长期记忆晋升。",
        "icon": "route",
        "fields": [
          {
            "path": ["ActionPlanner", "Enabled"],
            "label": "启用 Planner",
            "type": "boolean",
            "required": false
          },
          {
            "path": ["ActionPlanner", "MaxRepairAttempts"],
            "label": "Planner 修复次数",
            "type": "number",
            "min": 0,
            "step": 1,
            "required": false
          },
          {
            "path": ["ActionPlanner", "Evidence", "StalledStepLag"],
            "label": "证据停滞步距",
