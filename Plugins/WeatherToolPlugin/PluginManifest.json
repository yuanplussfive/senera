{
  "Plugin": {
    "Name": "WeatherToolPlugin",
    "Title": "天气查询",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Entry": {
      "Kind": "Process",
      "Command": "node",
      "Args": [
        "index.js"
      ],
      "Cwd": "."
    }
  },
  "Discovery": {
    "Tags": [
      "weather",
      "天气",
      "weatherapi",
      "qweather",
      "visual-crossing",
      "real-world",
      "forecast",
      "预报",
      "温度"
    ]
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 50
  },
  "Tools": [
    {
      "Name": "WeatherTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [
        "network:https://api.weatherapi.com",
        "network:https://devapi.qweather.com",
        "network:https://geoapi.qweather.com",
        "network:https://*.qweatherapi.com",
        "network:https://weather.visualcrossing.com"
      ],
      "Artifacts": {
        "Redact": {
          "Paths": [
            "$.apiKey"
          ]
        },
        "Evidence": [
          {
            "Kind": "weather_observation",
            "Records": "$",
            "Slots": {
              "resolvedLocation": "$.resolvedLocation",
              "sourceName": "$.source",
              "localTime": "$.localTime",
              "condition": "$.condition",
              "temperature": "$.temperature",
              "temperatureUnit": "$.temperatureUnit",
              "humidity": "$.humidity",
              "windSpeed": "$.windSpeed",
              "airQualityIndex": "$.airQualityIndex",
              "timezone": "$.timezone"
            },
            "Identity": {
              "Parts": [
                "resolvedLocation",
                "sourceName",
                {
                  "Slot": "localTime",
                  "Required": false
                }
              ]
            },
            "Presentation": {
              "RefPrefix": "WTH",
              "Locator": "{{ resolvedLocation }}",
              "Display": "current weather in {{ resolvedLocation }}: {{ condition }}, {{ temperature }}{{ temperatureUnit }}",
              "Label": "{{ resolvedLocation }}",
              "Source": "{{ sourceName }}"
            },
            "Confidence": 0.84,
            "Metadata": {
              "temperature": "$.temperature",
              "temperatureUnit": "$.temperatureUnit",
              "humidity": "$.humidity",
              "windSpeed": "$.windSpeed",
              "airQualityIndex": "$.airQualityIndex",
              "timezone": "$.timezone"
            },
            "ModelProjection": {
              "Slots": [
                "resolvedLocation",
                "sourceName",
                "localTime",
                "condition",
                "temperature",
                "temperatureUnit",
                "humidity",
                "windSpeed",
                "timezone"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "resolvedLocation",
                "sourceName",
                "localTime",
                "condition",
                "temperature",
                "temperatureUnit",
                "humidity",
                "windSpeed",
                "timezone"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- {{ e.ref }} current {{ e.slots.resolvedLocation }}: {{ e.slots.condition }}, {{ e.slots.temperature }}{{ e.slots.temperatureUnit }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- {{ e.ref }} current weather\n  location: {{ e.slots.resolvedLocation }}\n  localTime: {{ e.slots.localTime }}\n  condition: {{ e.slots.condition }}\n  temperature: {{ e.slots.temperature }}{{ e.slots.temperatureUnit }}\n  humidity: {{ e.slots.humidity }}\n  windSpeed: {{ e.slots.windSpeed }}\n  source: {{ e.slots.sourceName }}\n{% endfor %}"
            }
          },
          {
            "Kind": "weather_forecast_day",
            "Records": "$.forecast.item[*]",
            "Slots": {
              "resolvedLocation": {
                "Selector": "$.resolvedLocation",
                "Scope": "Root"
              },
              "sourceName": {
                "Selector": "$.source",
                "Scope": "Root"
              },
              "date": "$.date",
              "condition": "$.condition",
              "maxTemperature": "$.maxTemperature",
              "minTemperature": "$.minTemperature",
              "avgTemperature": "$.avgTemperature",
              "temperatureUnit": "$.temperatureUnit",
              "chanceOfRain": "$.chanceOfRain",
              "precipitation": "$.precipitation"
            },
            "Identity": {
              "Parts": [
                "resolvedLocation",
                "date",
                "sourceName"
              ]
            },
            "Presentation": {
              "RefPrefix": "FC",
              "Locator": "{{ resolvedLocation }} @ {{ date }}",
              "Display": "forecast for {{ resolvedLocation }} on {{ date }}: {{ condition }}",
              "Label": "{{ date }}",
              "Source": "{{ sourceName }}"
            },
            "Confidence": 0.8,
            "Metadata": {
              "maxTemperature": "$.maxTemperature",
              "minTemperature": "$.minTemperature",
              "avgTemperature": "$.avgTemperature",
              "temperatureUnit": "$.temperatureUnit",
              "chanceOfRain": "$.chanceOfRain",
              "precipitation": "$.precipitation"
            },
            "ModelProjection": {
              "Slots": [
                "resolvedLocation",
                "sourceName",
                "date",
                "condition",
                "maxTemperature",
                "minTemperature",
                "avgTemperature",
                "temperatureUnit",
                "chanceOfRain"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "resolvedLocation",
                "sourceName",
                "date",
                "condition",
                "maxTemperature",
                "minTemperature",
                "avgTemperature",
                "temperatureUnit",
                "chanceOfRain"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- {{ e.ref }} {{ e.slots.date }} {{ e.slots.resolvedLocation }}: {{ e.slots.condition }}, {{ e.slots.minTemperature }}-{{ e.slots.maxTemperature }}{{ e.slots.temperatureUnit }}, rain {{ e.slots.chanceOfRain }}%\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- {{ e.ref }} forecast day\n  location: {{ e.slots.resolvedLocation }}\n  date: {{ e.slots.date }}\n  condition: {{ e.slots.condition }}\n  temp: {{ e.slots.minTemperature }}-{{ e.slots.maxTemperature }}{{ e.slots.temperatureUnit }}\n  avg: {{ e.slots.avgTemperature }}{{ e.slots.temperatureUnit }}\n  rain: {{ e.slots.chanceOfRain }}%\n  source: {{ e.slots.sourceName }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "按城市、地区、地址或邮编查询当前天气和未来几天天气预报。",
        "Keywords": [
          "weather",
          "forecast",
          "temperature",
          "rain",
          "weatherapi",
          "qweather",
          "visual crossing",
          "天气",
          "气温",
          "温度",
          "下雨",
          "预报",
          "城市"
        ],
        "Capabilities": [
          {
            "Id": "weather.forecast",
            "Title": "Weather forecast",
            "Description": "Query current weather and multi-day forecasts for cities, regions, addresses, postal codes, or coordinates.",
            "Facets": {
              "Actions": [
                "query",
                "forecast",
                "observe"
              ],
              "Targets": [
                "weather",
                "forecast",
                "city",
                "location"
              ],
              "Inputs": [
                "location",
                "city",
                "address",
                "postal-code",
                "days",
                "language"
              ],
              "Outputs": [
                "weather-observation",
                "forecast-day",
                "temperature",
                "condition",
                "rain-probability"
              ],
              "Evidence": [
                "weather-observation",
                "weather-forecast-day"
              ],
              "Effects": [
                "network"
              ]
            },
            "Aliases": [
              "天气",
              "天气预报",
              "weather",
              "will it rain"
            ],
            "Examples": [
              "上海今天的天气怎么样",
              "东京未来三天天气"
            ],
            "Avoid": [
              "不要用于查询新闻、网页或本地代码"
            ],
            "Risk": {
              "SideEffect": "network",
              "Permission": "external-api",
              "Notes": [
                "Uses configured weather providers."
              ]
            }
          }
        ],
        "UseCases": [
          "用户询问天气、气温、降雨、城市预报或经纬度天气时使用。"
        ],
        "Examples": [
          "上海今天的天气怎么样",
          "北京明天会下雨吗",
          "weather in New York",
          "东京未来三天天气"
        ],
        "Avoid": [
          "不要用于查询新闻、网页或本地代码。"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "External",
    "Network": "Allow",
    "FileSystem": {
      "Read": [],
      "Write": []
    },
    "RequiresApproval": false
  }
}
