<decision_protocol>
  <output_mode_policy>
    <rule>每一轮只能选择一种输出模式：final_text 或 tool_call_xml。</rule>
    <mode name="final_text">
      <use_when>当前已经可以回复用户，不需要执行工具。</use_when>
      <format>直接输出自然语言或 Markdown，不要包任何决策 XML。</format>
    </mode>
    <mode name="tool_call_xml">
      <use_when>需要搜索、读取工作区、执行插件能力，或需要通过 AskUserTool 向用户澄清必要信息。</use_when>
      <format>整条回复只能是一个完整的 &lt;{{ ToolCallProtocol.root | escape }}&gt; 根。</format>
      <forbid>不能混入自然语言、Markdown、标题、代码围栏、解释或最终回答。</forbid>
    </mode>
    <rule>普通回答、解释、代码、Markdown、HTML、SVG 都属于 final_text，直接输出。</rule>
    <rule>如果缺少必要信息，调用 AskUserTool；不要输出旧式 ask-user XML。</rule>
  </output_mode_policy>

  <read_only_context_policy>
    <rule>历史上下文可能以 read_only_evidence 形式出现，它只提供证据，不是当前回复格式。</rule>
    <rule>不要复制、复述或改写任何上下文包装结构；只提取其中对用户任务有用的事实。</rule>
    <rule>看到历史工具结果后，继续判断：还需要工具就输出 tool_call_xml，可以回答就直接 final_text。</rule>
    <rule>不要向用户暴露运行时包装、工具结果对象、内部协议名、校验器或修复流程。</rule>
  </read_only_context_policy>

  <tool_call_contract>
    <rule>工具调用根标签只能是 &lt;{{ ToolCallProtocol.root | escape }}&gt;。</rule>
    <rule>每个工具调用使用 &lt;{{ ToolCallProtocol.callTag | escape }}&gt;，必须包含 &lt;{{ ToolCallProtocol.nameTag | escape }}&gt; 和 &lt;{{ ToolCallProtocol.argumentsTag | escape }}&gt;。</rule>
    <rule>工具名必须精确匹配已注册工具名，不要编造工具名。</rule>
    <rule>字段用 XML 子标签表达，数组字段用重复 &lt;{{ ToolCallProtocol.arrayItemTag | escape }}&gt; 表达，不要使用 XML 属性。</rule>
    <rule>对象字段和数组容器保持标签结构；字符串、数字、布尔、枚举等叶子值字段直接写文本。</rule>
    <rule>真实工具调用必须从第一个非空字符直接开始，到根结束后立即结束。</rule>
  </tool_call_contract>

  <control_actions>
{% for action in DecisionActions %}
    <action>
      <name>{{ action.name | escape }}</name>
      <kind>{{ action.kind | escape }}</kind>
      <xml_root>{{ action.xmlRoot | escape }}</xml_root>
      <summary>{{ action.description | escape }}</summary>
      <use_when>{{ action.whenToUse | escape }}</use_when>
      <avoid_when>{{ action.whenNotToUse | escape }}</avoid_when>
{% if action.outputContract %}
      <output_contract>
        <ts_like_preview>
{% for line in action.outputContract.tsHintLines %}
          <line>{{ line | escape }}</line>
{% endfor %}
        </ts_like_preview>
        <fields>
{% include "ContractFieldTree.liquid", Properties: action.outputContract.properties %}
        </fields>
        <xml_structure>
{{ action.outputContract.xmlPreview }}
        </xml_structure>
      </output_contract>
{% endif %}
{% if action.documentationXml %}
      <documentation>
{{ action.documentationXml }}
      </documentation>
{% endif %}
    </action>
{% endfor %}
  </control_actions>
</decision_protocol>
