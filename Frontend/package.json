    "parse5": "^7.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^9.0.1",
    "react-virtuoso": "^4.18.7",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.0",
