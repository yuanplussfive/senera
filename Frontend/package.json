{
  "name": "senera-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check.types": "tsc --noEmit",
    "check.governance": "node --import tsx ../Scripts/VerifyFrontendTestCoverage.ts",
    "test.behavior": "node --import tsx ../Scripts/VerifyFrontendVitestSuite.ts",
    "test.coverage": "vitest run --config ../vitest.config.ts --coverage",
    "test": "npm run check.types && npm run check.governance && npm run test.behavior"
  },
  "dependencies": {
