{
  "ManifestVersion": 2,
  "Contracts": { "File": "./ToolContracts.json" },
  "Plugin": {
    "Name": "TavilySearchToolPlugin",
    "Title": "网页搜索",
    "Version": "0.1.0",
    "Kind": "Tool"
  },
  "Discovery": {
    "Sources": [
      {
        "Id": "web",
        "Title": "Web",
        "Description": "Public internet information, online services, and current external data."
      }
    ]
  },
  "McpServers": [
    {
      "Id": "tavily",
      "Transport": "stdio",
      "Command": "${node}",
      "Args": ["${pluginRoot}/index.js"],
      "Cwd": "${pluginRoot}"
    }
  ],
  "Sandbox": {
    "Network": "Allow",
    "Workspace": {
      "Read": ["PluginConfig.toml"],
      "Write": []
    },
    "State": {
      "Write": [".state"]
    }
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 68
  },
  "Tools": [
    {
      "Name": "TavilySearchTool",
      "Loading": "Dynamic",
      "DescriptionFile": "./docs/Tool.md",
      "Permissions": ["network:https://api.tavily.com", "filesystem:read:PluginConfig.toml", "filesystem:write:.state"],
      "Execution": {
        "Targets": ["Local"],
        "Network": "Allow",
        "Workspace": "ReadWrite"
      },
      "Artifacts": {
        "Redact": {
          "Paths": ["$.apiKey"]
        },
        "Evidence": [
          {
            "Kind": "web_result",
            "Records": "$.results.item[*]",
            "Slots": {
              "title": "$.title",
              "url": "$.url",
              "content": "$.content",
              "score": "$.score",
              "publishedDate": "$.publishedDate",
              "favicon": "$.favicon"
            },
            "Identity": {
              "Parts": ["url"]
            },
            "Presentation": {
              "Locator": "{{ url }}",
              "Display": "web result: {{ title }}",
              "Label": "{{ title }}",
              "Source": "{{ content }}"
            },
            "Confidence": 0.82,
            "Metadata": {
              "score": "$.score",
              "publishedDate": "$.publishedDate",
              "favicon": "$.favicon"
            },
            "ModelProjection": {
              "Slots": ["title", "url", "content", "score", "publishedDate"]
            },
            "PlannerMemory": {
              "Facts": ["title", "url", "score", "publishedDate"],
              "ArtifactRefs": ["evidence", "projection"]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.title }} - {{ e.slots.url }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} web result\n  title: {{ e.slots.title }}\n  url: {{ e.slots.url }}\n  score: {{ e.slots.score }}{% if e.slots.publishedDate %}\n  published: {{ e.slots.publishedDate }}{% endif %}\n  content: {{ e.slots.content }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "联网搜索网页、新闻和实时事实信息。",
        "Tags": ["网页搜索", "最新消息", "外部资料", "新闻查询", "联网检索"],
        "Capabilities": [
          {
            "Id": "web.search",
            "Title": "Web search",
            "Description": "Search external web pages, current news, public documentation, and real-world facts.",
            "Facets": {
              "Actions": ["search", "lookup", "verify"],
              "Targets": ["web", "news", "public-documentation", "current-fact", "external-source"],
              "Inputs": ["query", "domain", "date-range", "topic", "country"],
              "Outputs": ["web-result", "url", "source-snippet", "answer-summary"],
              "Evidence": ["web-result"],
              "Effects": ["network"]
            },
            "Aliases": ["联网搜索", "网页搜索", "latest news", "official docs lookup"],
            "Risk": {
              "SideEffect": "network",
              "Permission": "external-api",
              "Notes": ["Sends the search query to Tavily."]
            }
          }
        ],
        "UseCases": [
          "需要查询当前新闻、官网资料、实时事件或外部网页时使用。",
          "需要比较产品、公司、政策、价格、发布时间等可能变化的信息时使用。"
        ],
        "Examples": ["OpenAI 最新新闻", "Tavily API 文档", "公司最近动态 对比", "latest release notes web search"],
        "Avoid": ["不要用于搜索本地代码或读取工作区文件。"]
      },
      "Handler": {
        "Kind": "McpTool",
        "Server": "tavily",
        "Tool": "TavilySearchTool"
      },
      "Runtime": {
        "Lifecycle": "Persistent",
        "Capabilities": {
          "Progress": true,
          "OutputStreaming": true,
          "Cancellation": true
        }
      }
    }
  ],
  "Security": {
    "TrustLevel": "External",
    "Network": "Allow",
    "FileSystem": {
      "Read": ["PluginConfig.toml"],
      "Write": [".state"]
    },
    "RequiresApproval": false
  }
}
