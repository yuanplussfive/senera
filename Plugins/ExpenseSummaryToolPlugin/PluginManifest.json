{
  "Plugin": {
    "Name": "ExpenseSummaryToolPlugin",
    "Title": "Expense Summary Tool",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Entry": {
      "Kind": "Process",
      "Command": "node",
      "Args": [
        "index.js"
      ],
      "Cwd": "."
    }
  },
  "Discovery": {
    "Tags": [
      "finance",
      "财务",
      "expense",
      "费用",
      "settlement",
      "local",
      "分摊",
      "报销",
      "记账"
    ]
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 56
  },
  "Tools": [
    {
      "Name": "ExpenseSummaryTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [],
      "Search": {
        "Summary": "汇总多人费用流水并计算分摊、应收应付和结算建议。",
        "Keywords": [
          "expense",
          "split",
          "settlement",
          "reimbursement",
          "finance",
          "费用",
          "分账",
          "分摊",
          "结算",
          "报销",
          "AA"
        ],
        "UseCases": [
          "需要根据付款人、参与人、金额和权重计算费用分摊时使用。"
        ],
        "Examples": [
          "帮我算这几笔旅行费用怎么 AA",
          "汇总报销流水并给出谁付给谁",
          "split expenses among participants"
        ],
        "Avoid": [
          "不要用于实时金融行情或外部财经新闻搜索。"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "Local",
    "Network": "Deny",
    "FileSystem": {
      "Read": [],
      "Write": []
    },
    "RequiresApproval": false
  }
}
