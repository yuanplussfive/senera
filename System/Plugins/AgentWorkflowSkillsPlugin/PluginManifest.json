{
  "Plugin": {
    "Name": "AgentWorkflowSkillsPlugin",
    "Title": "工作流技能",
    "Version": "0.1.0",
    "Kind": "Skill",
    "Description": "提供面向模型的可复用工作流技能，指导复杂任务的检索、取证、验证和输出。"
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 45
  },
  "Skills": [
    {
      "Name": "WorkspaceInvestigationSkill",
      "Title": "工作区调查",
      "DescriptionFile": "./docs/WorkspaceInvestigation.md",
      "RecommendedTools": [
        "AgentDelegateTool",
        "FastContextWorkspaceMapTool",
        "FastContextHybridSearchTool",
        "FastContextSearchTool",
        "FastContextSymbolSearchTool",
        "FastContextReadTool"
      ],
      "RecommendedAgents": [
        "WorkspaceExplorer",
        "SymbolTracer"
      ],
      "RecommendedWorkflows": [
        "WorkspaceInvestigationWorkflow"
      ],
      "Search": {
        "Summary": "定位代码、配置、提示词、UI 文案、错误处理或跨文件实现时，按搜索、读取、再搜索、取证的闭环工作。",
        "Capabilities": [
          {
            "Id": "workflow.workspace-investigation",
            "Title": "Workspace investigation workflow",
            "Description": "Guide local code investigation through search, candidate reading, query refinement, and evidence-backed conclusions.",
            "Facets": {
              "Actions": [
                "investigate",
                "search",
                "read",
                "verify"
              ],
              "Targets": [
                "workspace",
                "source-code",
                "configuration",
                "prompt-template",
                "ui-code"
              ],
              "Inputs": [
                "natural-language",
                "identifier",
                "path",
                "error-text",
                "ui-description"
              ],
              "Outputs": [
                "source-location",
                "evidence-backed-summary",
                "next-edit-target"
              ],
              "Evidence": [
                "workspace-search-match",
                "workspace-read"
              ],
              "Effects": [
                "read-only",
                "index-cache"
              ]
            },
            "Aliases": [
              "代码调查",
              "搜索读取闭环",
              "find code and verify",
              "search read refine"
            ],
            "Risk": {
              "SideEffect": "index-cache",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "本地功能、错误、UI、配置、提示词实现调查。",
          "项目用途、代码库入口、主要模块、README、package、配置证据读取。",
          "搜索候选、读取文件、继续追踪、证据支持结论。"
        ],
        "Examples": [
          "插件工作区索引实现",
          "停止按钮执行取消逻辑",
          "planner 上下文构建",
          "项目用途 README package",
          "代码库入口模块"
        ],
        "Avoid": [
          "无需本地工作区事实的闲聊、解释或纯设计讨论。"
        ],
        "Tags": [
          "项目调查",
          "代码理解",
          "工作区检索",
          "文件阅读",
          "问题定位"
        ]
      },
      "EvidenceRequirements": [
        {
          "Need": "workspace read source-of-truth evidence",
          "Accepts": [
            "workspace read",
            "project identity",
            "project purpose",
            "implementation detail",
            "source behavior"
          ],
          "MinimumQuality": [
            "observed"
          ],
          "Minimum": 1,
          "Purpose": "本地工作区结论需要来自已读取的文件、目录读取或源码片段；项目地图和搜索候选只用于定位，不满足最终回答。"
        }
      ]
    },
    {
      "Name": "PullRequestReviewSkill",
      "Title": "变更审查",
      "DescriptionFile": "./docs/PullRequestReview.md",
      "RecommendedTools": [
        "AgentDelegateTool",
        "FastContextReadTool",
        "FastContextHybridSearchTool",
        "FastContextSearchTool",
        "ApplyPatchTool"
      ],
      "RecommendedAgents": [
        "SecurityReviewer",
        "TestGapReviewer",
        "MaintainabilityReviewer"
      ],
      "RecommendedWorkflows": [
        "ParallelPullRequestReview"
      ],
      "Search": {
        "Summary": "审查 PR、diff 或未提交变更时，优先找风险、回归、测试缺口和框架影响。",
        "Capabilities": [
          {
            "Id": "workflow.change-review",
            "Title": "Change review workflow",
            "Description": "Guide review of local or PR changes with risk-first findings, source references, and verification gaps.",
            "Facets": {
              "Actions": [
                "review",
                "inspect",
                "verify"
              ],
              "Targets": [
                "diff",
                "pull-request",
                "workspace-change",
                "test-coverage"
              ],
              "Inputs": [
                "diff",
                "commit",
                "changed-files",
                "user-claim"
              ],
              "Outputs": [
                "findings",
                "risk-summary",
                "test-gap"
              ],
              "Evidence": [
                "workspace-read",
                "workspace-search-match"
              ],
              "Effects": [
                "read-only"
              ]
            },
            "Aliases": [
              "PR 审查",
              "代码审查",
              "review changes",
              "diff review"
            ],
            "Risk": {
              "SideEffect": "none",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "PR、合并变更、未提交 diff、风险、回归、测试缺口审查。"
        ],
        "Examples": [
          "PR 变更风险审查",
          "合并变更框架影响",
          "diff regression risk"
        ],
        "Avoid": [
          "纯需求分析或无需检查实际变更时不要激活。"
        ],
        "Tags": [
          "代码审查",
          "变更分析",
          "风险评估",
          "回归检查",
          "测试建议"
        ]
      }
    },
