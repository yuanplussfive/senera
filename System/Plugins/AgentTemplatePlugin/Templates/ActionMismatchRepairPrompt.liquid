<repair_request>
  <reason>
    <code>{{ code | escape }}</code>
    <expected>{{ expected | escape }}</expected>
    <actual>{{ actual | escape }}</actual>
  </reason>

{% if RootCommand %}
  <root_command_projection>
    <authority>{{ RootCommand.authority | escape }}</authority>
    <action>{{ RootCommand.action | escape }}</action>
    <output_mode>{{ RootCommand.outputMode | escape }}</output_mode>
    <tool_access>{{ RootCommand.toolAccess | escape }}</tool_access>
    <objective>{{ RootCommand.objective | escape }}</objective>
{% if RootCommand.instruction %}
    <instruction>{{ RootCommand.instruction | escape }}</instruction>
{% endif %}
    <visible_output_contract>
      <audience>{{ RootCommand.visibleOutput.audience | escape }}</audience>
      <start>{{ RootCommand.visibleOutput.start | escape }}</start>
      <format>{{ RootCommand.visibleOutput.format | escape }}</format>
      <rules>
{% for rule in RootCommand.visibleOutput.rules %}
        <rule>
          <name>{{ rule.name | escape }}</name>
          <value>{{ rule.value | escape }}</value>
{% if rule.instruction %}
          <instruction>{{ rule.instruction | escape }}</instruction>
{% endif %}
        </rule>
{% endfor %}
      </rules>
    </visible_output_contract>
  </root_command_projection>

  <repair_contract>
    <instruction>{{ RootCommand.visibleOutput.repair.instruction | escape }}</instruction>
    <rules>
{% for rule in RootCommand.visibleOutput.repair.rules %}
      <rule>
        <name>{{ rule.name | escape }}</name>
        <value>{{ rule.value | escape }}</value>
{% if rule.instruction %}
        <instruction>{{ rule.instruction | escape }}</instruction>
{% endif %}
      </rule>
{% endfor %}
    </rules>
  </repair_contract>
{% endif %}

{% if tools.size > 0 %}
  <tool_call_repair_context>
    <tool_call_root>{{ ToolCallProtocol.root | escape }}</tool_call_root>
    <call_tag>{{ ToolCallProtocol.callTag | escape }}</call_tag>
    <name_tag>{{ ToolCallProtocol.nameTag | escape }}</name_tag>
    <arguments_tag>{{ ToolCallProtocol.argumentsTag | escape }}</arguments_tag>
    <allowed_tools>
{% for tool in tools %}
      <tool>
        <name>{{ tool.name | escape }}</name>
        <summary>{{ tool.summary | escape }}</summary>
{% if tool.examples.size > 0 %}
        <examples>
{% for example in tool.examples limit: 2 %}
          <example>{{ example | escape }}</example>
{% endfor %}
        </examples>
{% endif %}
      </tool>
{% endfor %}
    </allowed_tools>
    <xml_shape>
      <root>&lt;{{ ToolCallProtocol.root | escape }}&gt;</root>
      <call>&lt;{{ ToolCallProtocol.callTag | escape }}&gt;</call>
      <name>&lt;{{ ToolCallProtocol.nameTag | escape }}&gt;allowed_tool_name&lt;/{{ ToolCallProtocol.nameTag | escape }}&gt;</name>
      <arguments>&lt;{{ ToolCallProtocol.argumentsTag | escape }}&gt;...&lt;/{{ ToolCallProtocol.argumentsTag | escape }}&gt;</arguments>
    </xml_shape>
  </tool_call_repair_context>
{% endif %}
</repair_request>
