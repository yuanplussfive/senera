      "Search": {
        "Summary": "审查 PR、diff 或未提交变更时，优先找风险、回归、测试缺口和框架影响。",
        "Keywords": [
          "review",
          "diff",
          "pull request",
          "pr",
          "change",
          "risk",
          "审查",
          "变更",
          "风险",
          "回归",
          "测试"
        ],
        "Capabilities": [
          {
            "Id": "workflow.change-review",
            "Title": "Change review workflow",
            "Description": "Guide review of local or PR changes with risk-first findings, source references, and verification gaps.",
            "Facets": {
              "Actions": [
                "review",
                "inspect",
                "verify"
              ],
              "Targets": [
                "diff",
                "pull-request",
                "workspace-change",
                "test-coverage"
              ],
              "Inputs": [
                "diff",
                "commit",
                "changed-files",
                "user-claim"
              ],
              "Outputs": [
                "findings",
                "risk-summary",
                "test-gap"
              ],
              "Evidence": [
                "workspace-read",
                "workspace-search-match"
              ],
              "Effects": [
                "read-only"
              ]
            },
            "Aliases": [
              "PR 审查",
              "代码审查",
              "review changes",
              "diff review"
            ],
            "Examples": [
              "有人提交了 PR，看看有没有害",
              "审查这次改动是否影响框架"
            ],
            "Avoid": [
              "用户明确要求直接实现新功能时不要只做审查"
            ],
            "Risk": {
              "SideEffect": "none",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "用户要求查看 PR、合并变更、未提交 diff、是否有风险或是否影响框架。"
        ],
        "Examples": [
          "看看这个 PR 是干嘛的，有没有害",
          "合并后这些改动会不会影响我们的框架"
        ],
        "Avoid": [
          "纯需求分析或无需检查实际变更时不要激活。"
        ]
      }
    },
