{
  "Plugin": {
    "Name": "FastContextWorkspaceMapToolPlugin",
    "Title": "项目地图",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Entry": {
      "Kind": "Process",
      "Command": "node",
      "Args": [
        "index.js"
      ],
      "Cwd": "."
    }
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 68
  },
  "Tools": [
    {
      "Name": "FastContextWorkspaceMapTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [
        "filesystem:read:workspace"
      ],
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "workspace_map_path",
            "Records": "$.topLevel.item[*]",
            "Slots": {
              "path": "$.path",
              "kind": "$.kind",
              "purpose": "$.purpose"
            },
            "Identity": {
              "Parts": [
                "path"
              ]
            },
            "Presentation": {
              "Locator": "{{ path }}",
              "Display": "workspace {{ kind }}: {{ path }}",
              "Label": "{{ path }}",
              "Source": "{{ purpose }}"
            },
            "Confidence": 0.72,
            "Metadata": {
              "kind": "$.kind"
            },
            "ModelProjection": {
              "Slots": [
                "path",
                "kind",
                "purpose"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "path",
                "kind",
                "purpose"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.kind }} {{ e.slots.path }} - {{ e.slots.purpose }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} workspace path\n  path: {{ e.slots.path }}\n  kind: {{ e.slots.kind }}\n  purpose: {{ e.slots.purpose }}\n{% endfor %}"
            }
          },
          {
            "Kind": "workspace_marker_file",
            "Records": "$.project.markers.item[*]",
            "Slots": {
              "path": "$"
            },
            "Identity": {
              "Parts": [
                "path"
              ]
            },
            "Presentation": {
              "Locator": "{{ path }}",
              "Display": "workspace marker file: {{ path }}",
              "Label": "{{ path }}",
              "Source": "project marker"
            },
            "Confidence": 0.84,
            "ModelProjection": {
              "Slots": [
                "path"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "path"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} marker file: {{ e.slots.path }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} marker file\n  path: {{ e.slots.path }}\n{% endfor %}"
            }
          },
          {
            "Kind": "workspace_source_root",
            "Records": "$.project.sourceRoots.item[*]",
            "Slots": {
              "root": "$"
            },
            "Identity": {
              "Parts": [
                "root"
              ]
            },
            "Presentation": {
              "Locator": "{{ root }}",
              "Display": "workspace source root: {{ root }}",
              "Label": "{{ root }}",
              "Source": "source root"
            },
            "Confidence": 0.8,
            "ModelProjection": {
              "Slots": [
                "root"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "root"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} source root: {{ e.slots.root }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} source root\n  root: {{ e.slots.root }}\n{% endfor %}"
            }
          },
          {
            "Kind": "workspace_entry_point",
            "Records": "$.project.entryPoints.item[*]",
            "Slots": {
              "root": "$"
            },
            "Identity": {
              "Parts": [
                "root"
              ]
            },
            "Presentation": {
              "Locator": "{{ root }}",
              "Display": "workspace entry point: {{ root }}",
              "Label": "{{ root }}",
              "Source": "entry point"
            },
            "Confidence": 0.8,
            "ModelProjection": {
              "Slots": [
                "root"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "root"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} entry point: {{ e.slots.root }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} entry point\n  root: {{ e.slots.root }}\n{% endfor %}"
            }
          },
          {
            "Kind": "workspace_recommended_root",
            "Records": "$.project.recommendedRoots.item[*]",
            "Slots": {
              "root": "$"
            },
            "Identity": {
              "Parts": [
                "root"
              ]
            },
            "Presentation": {
              "Locator": "{{ root }}",
              "Display": "recommended workspace root: {{ root }}",
              "Label": "{{ root }}",
              "Source": "{{ root }}"
            },
            "Confidence": 0.78,
            "ModelProjection": {
              "Slots": [
                "root"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "root"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} recommended root: {{ e.slots.root }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} recommended root\n  root: {{ e.slots.root }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "快速查看工作区目录结构、项目标记文件和主要文件分布。",
        "Tags": [
          "项目地图",
          "目录结构",
          "文件树",
          "配置发现",
          "工作区概览"
        ],
        "Capabilities": [
          {
            "Id": "workspace.map",
            "Title": "Workspace map",
            "Description": "Inspect top-level workspace structure, project marker files, roots, and likely source areas before selecting files.",
            "Facets": {
              "Actions": [
                "inspect",
                "map",
                "orient"
              ],
              "Targets": [
                "workspace",
                "directory-tree",
                "project-structure",
                "marker-file",
                "configuration"
              ],
              "Inputs": [
                "workspace-root",
                "path"
              ],
              "Outputs": [
                "directory-summary",
                "marker-file",
                "recommended-root",
                "path-reference"
              ],
              "Evidence": [
                "workspace-map-path",
                "workspace-marker-file",
                "workspace-recommended-root"
              ],
              "Effects": [
                "read-only"
              ]
            },
            "Aliases": [
              "项目地图",
              "目录结构",
              "workspace tree",
              "project layout"
            ],
            "Risk": {
              "SideEffect": "none",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "不清楚项目结构、需要先看有哪些目录或根目录标记文件、避免猜路径时使用。"
        ],
        "Examples": [
          "工作区目录结构",
          "项目根目录标记文件",
          "文件树 项目结构",
          "workspace tree"
        ],
        "Avoid": [
          "不要用于读取完整文件内容或精确搜索代码。"
        ]
      },
      "EvidenceCapabilities": [
        {
          "Produces": "workspace map",
          "Quality": "observed",
          "Satisfies": [
            "project orientation",
            "project structure",
            "project marker files",
            "project configuration location",
            "workspace orientation",
            "workspace investigation entrypoint"
          ],
          "Kinds": [
            "workspace_map_path",
            "workspace_marker_file",
            "workspace_source_root",
            "workspace_entry_point",
            "workspace_recommended_root"
          ],
          "CapabilityIds": [
            "workspace.map"
          ]
        }
      ]
    }
  ],
  "Security": {
    "TrustLevel": "Local",
    "Network": "Deny",
    "FileSystem": {
      "Read": [
        "../.."
      ],
      "Write": []
    },
    "RequiresApproval": false
  }
}
