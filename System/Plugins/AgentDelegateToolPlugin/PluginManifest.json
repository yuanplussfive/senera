{
  "Plugin": {
    "Name": "AgentDelegateToolPlugin",
    "Title": "代理委派规划",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Description": "根据插件声明的 workflow 生成子代理委派计划，并可启动子代理循环。"
  },
  "Discovery": {
    "Tags": [
      "agent",
      "delegate",
      "workflow",
      "subagent",
      "plan",
      "代理",
      "子代理",
      "工作流",
      "委派",
      "规划"
    ]
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 9
  },
  "Tools": [
    {
      "Name": "AgentDelegateTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [],
      "Handler": {
        "Kind": "HostCapability",
        "Capability": "agent.delegate"
      },
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "agent_delegation_job",
            "Records": "$.jobs.item[*]",
            "Slots": {
              "jobId": "$.jobId",
              "workflowName": "$.workflowName",
              "agentName": "$.agentName",
              "agentTitle": "$.agentTitle",
              "status": "$.status",
              "taskFile": "$.taskFile",
              "contextPack": "$.contextPack",
              "contextTemplateFile": "$.contextTemplateFile",
              "toolScope": "$.toolScope",
              "historyPolicy": "$.historyPolicy",
              "artifactPolicy": "$.artifactPolicy",
              "evidencePolicy": "$.evidencePolicy",
              "runtimeProfile": "$.runtimeProfile",
              "outputSchema": "$.outputSchema",
              "recommendedTools": "$.recommendedTools.item"
            },
            "Identity": {
              "Parts": [
                "jobId"
              ]
            },
            "Presentation": {
              "RefPrefix": "AGT",
              "Locator": "{{ workflowName }}#{{ jobId }}",
              "Display": "{{ agentName }} planned for {{ workflowName }}",
              "Label": "{{ agentTitle }}",
              "Source": "{{ taskFile }}"
            },
            "Confidence": 0.9,
            "Metadata": {
              "workflowName": "$.workflowName",
              "agentName": "$.agentName",
              "contextPack": "$.contextPack",
              "contextTemplateFile": "$.contextTemplateFile",
              "runtimeProfile": "$.runtimeProfile",
              "outputSchema": "$.outputSchema"
            },
            "ModelProjection": {
              "Slots": [
                "workflowName",
                "agentName",
                "agentTitle",
                "status",
                "taskFile",
                "contextPack",
                "contextTemplateFile",
                "toolScope",
                "historyPolicy",
                "artifactPolicy",
                "evidencePolicy",
                "runtimeProfile",
                "outputSchema",
                "recommendedTools"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "workflowName",
                "agentName",
                "status",
                "contextPack",
                "runtimeProfile",
                "outputSchema"
              ],
              "ArtifactRefs": [
                "projection",
                "evidence"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- {{ e.ref }} {{ e.slots.agentName }} planned for {{ e.slots.workflowName }} using {{ e.slots.contextPack }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- {{ e.ref }} agent delegation job\n  workflow: {{ e.slots.workflowName }}\n  agent: {{ e.slots.agentName }}\n  title: {{ e.slots.agentTitle }}\n  status: {{ e.slots.status }}\n  task: {{ e.slots.taskFile }}\n  contextPack: {{ e.slots.contextPack }}\n  contextTemplate: {{ e.slots.contextTemplateFile }}\n  toolScope: {{ e.slots.toolScope }}\n  history: {{ e.slots.historyPolicy }}\n  artifacts: {{ e.slots.artifactPolicy }}\n  evidence: {{ e.slots.evidencePolicy }}\n  runtimeProfile: {{ e.slots.runtimeProfile }}\n  outputSchema: {{ e.slots.outputSchema }}\n  recommendedTools: {{ e.slots.recommendedTools }}\n{% endfor %}"
            }
          },
          {
            "Kind": "agent_child_result",
            "Records": "$.run.delegation.jobs.item[*]",
            "Slots": {
              "jobId": "$.jobId",
              "workflowName": "$.workflowName",
              "agentName": "$.agentName",
              "status": "$.status",
              "mode": "$.mode",
              "text": "$.text",
              "terminalKind": "$.loopResult.terminal.kind"
            },
            "Identity": {
              "Parts": [
                "jobId",
                "mode"
              ]
            },
            "Presentation": {
              "RefPrefix": "ACR",
              "Locator": "{{ workflowName }}#{{ jobId }}",
              "Display": "{{ agentName }} completed via {{ mode }}",
              "Label": "{{ agentName }} result",
              "Source": "{{ text }}"
            },
            "Confidence": 0.86,
            "Metadata": {
              "workflowName": "$.workflowName",
              "agentName": "$.agentName",
              "mode": "$.mode",
              "terminalKind": "$.loopResult.terminal.kind"
            },
            "ModelProjection": {
              "Slots": [
                "workflowName",
                "agentName",
                "status",
                "mode",
                "terminalKind",
                "text"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "workflowName",
                "agentName",
                "status",
                "mode",
                "terminalKind",
                "text"
              ],
              "ArtifactRefs": [
                "projection",
                "evidence"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- {{ e.ref }} {{ e.slots.agentName }} completed via {{ e.slots.mode }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- {{ e.ref }} child agent result\n  workflow: {{ e.slots.workflowName }}\n  agent: {{ e.slots.agentName }}\n  status: {{ e.slots.status }}\n  mode: {{ e.slots.mode }}\n  terminal: {{ e.slots.terminalKind }}\n  text: {{ e.slots.text }}\n{% endfor %}"
            }
          },
          {
            "Kind": "agent_merge_result",
            "Records": "$.run.merge",
            "Slots": {
              "workflowName": "$.workflowName",
              "mergePolicyName": "$.mergePolicyName",
              "status": "$.status",
              "mode": "$.mode",
              "text": "$.text"
            },
            "Identity": {
              "Parts": [
                "workflowName",
                "mergePolicyName"
              ]
            },
            "Presentation": {
              "RefPrefix": "AMR",
              "Locator": "{{ workflowName }}#{{ mergePolicyName }}",
              "Display": "{{ mergePolicyName }} merged {{ workflowName }}",
              "Label": "{{ mergePolicyName }} merge",
              "Source": "{{ text }}"
            },
            "Confidence": 0.88,
            "Metadata": {
              "workflowName": "$.workflowName",
              "mergePolicyName": "$.mergePolicyName",
              "mode": "$.mode"
            },
            "ModelProjection": {
              "Slots": [
                "workflowName",
                "mergePolicyName",
                "status",
                "mode",
                "text"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "workflowName",
                "mergePolicyName",
                "status",
                "mode",
                "text"
              ],
              "ArtifactRefs": [
                "projection",
                "evidence"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- {{ e.ref }} {{ e.slots.mergePolicyName }} merged {{ e.slots.workflowName }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- {{ e.ref }} merge result\n  workflow: {{ e.slots.workflowName }}\n  mergePolicy: {{ e.slots.mergePolicyName }}\n  status: {{ e.slots.status }}\n  mode: {{ e.slots.mode }}\n  text: {{ e.slots.text }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}"
        }
      },
      "Search": {
        "Summary": "根据插件声明的 workflow 生成子代理委派计划，或启动子代理循环并合并结果，适用于并行审查、分工调查、记忆建模和文档理解等多代理任务。",
        "Keywords": [
          "agent",
          "delegate",
          "subagent",
          "workflow",
          "parallel",
          "review",
          "investigation",
          "memory",
          "document",
          "代理",
          "子代理",
          "委派",
          "并行",
          "工作流",
          "审查",
          "调查"
        ],
        "Capabilities": [
          {
            "Id": "agent.workflow-delegation-plan",
            "Title": "Agent workflow delegation plan",
            "Description": "Resolve a registered workflow into child-agent jobs, then optionally run child agent loops and merge the results.",
            "Facets": {
              "Actions": [
                "delegate",
                "plan",
                "split",
                "coordinate"
              ],
              "Targets": [
                "workflow",
                "subagent",
                "agent-job",
                "multi-agent-task"
              ],
              "Inputs": [
                "workflow-name",
                "objective",
                "evidence-ref",
                "artifact-uri"
              ],
              "Outputs": [
                "delegation-plan",
                "delegation-run",
                "agent-job",
                "merge-policy",
                "context-pack"
              ],
              "Evidence": [
                "agent-delegation-job"
              ],
              "Effects": [
                "read-only",
                "artifact-write"
              ]
            },
            "Aliases": [
              "规划子代理",
              "并行代理计划",
              "delegate to agents",
              "subagent plan"
            ],
            "Examples": [
              "为当前 PR 生成并行审查子代理计划",
              "按推荐 workflow 规划多个调查代理",
              "plan subagents for memory formation"
            ],
            "Avoid": [
              "只需要直接回答或单个普通工具调用时不要使用。",
              "没有已注册 workflow 名时不要猜测。"
            ],
            "Risk": {
              "SideEffect": "artifact-write",
              "Permission": "none"
            }
          }
        ],
        "UseCases": [
          "active skill 暴露了 recommended_workflows，且用户需要多角色或并行处理。",
          "需要把插件声明的 agents/context packs/merge policy 投影成可保存、可观察的计划。",
          "准备进入后续真正 agent runtime 前，先确认子任务拆分和证据输入。",
          "用户明确要求实际使用子代理处理任务时，使用 executionMode=run。"
        ],
        "Examples": [
          "使用 ParallelPullRequestReview 规划并行审查",
          "为长期记忆建模生成候选记忆和知识关系两个子任务",
          "把 DocumentUnderstandingWorkflow 展开成文档检查和视觉检查任务"
        ],
        "Avoid": [
          "executionMode=plan 的结果不是已经执行了子代理。",
          "不要在 workflow 未注册时调用。"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "System",
    "Network": "Deny",
    "FileSystem": {
      "Read": [],
      "Write": []
    },
    "RequiresApproval": false
  }
}
