{
  "Plugin": {
    "Name": "AgentImageVisionPlugin",
    "Title": "图片识别",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Description": "按 uploadUri 读取用户上传图片，并通过插件配置的视觉模型进行识别、OCR 或问答。"
  },
  "Discovery": {
    "Tags": [
      "image",
      "vision",
      "ocr",
      "upload",
      "图片",
      "截图",
      "识图"
    ]
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 8
  },
  "Tools": [
    {
      "Name": "ImageVisionTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [
        "filesystem:read:uploads",
        "network:model-provider"
      ],
      "Handler": {
        "Kind": "HostCapability",
        "Capability": "image.vision"
      },
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "image_vision_result",
            "Records": "$.images.item[*]",
            "Slots": {
              "uploadUri": "$.uploadUri",
              "status": "$.status",
              "task": "$.task",
              "question": "$.question",
              "name": "$.name",
              "mime": "$.mime",
              "size": "$.size",
              "answer": "$.answer",
              "providerId": "$.providerId",
              "providerEndpoint": "$.providerEndpoint",
              "providerModel": "$.providerModel",
              "message": "$.message"
            },
            "Identity": {
              "Parts": [
                "uploadUri",
                "task",
                {
                  "Slot": "question",
                  "Required": false
                }
              ]
            },
            "Presentation": {
              "RefPrefix": "IMG",
              "Locator": "{{ uploadUri }}",
              "Display": "image vision {{ status }}: {{ name }}",
              "Label": "{{ name }}",
              "Source": "{{ providerModel }}"
            },
            "Confidence": 0.9,
            "Metadata": {
              "status": "$.status",
              "task": "$.task",
              "mime": "$.mime",
              "providerId": "$.providerId",
              "providerModel": "$.providerModel"
            },
            "ModelProjection": {
              "Slots": [
                "uploadUri",
                "status",
                "task",
                "question",
                "name",
                "mime",
                "answer",
                "providerModel",
                "message"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "uploadUri",
                "status",
                "task",
                "question",
                "name",
                "mime",
                "providerModel"
              ],
              "ArtifactRefs": [
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- {{ e.ref }} {{ e.slots.status }} {{ e.slots.name }} task={{ e.slots.task }}\n  answer: {{ e.slots.answer }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- {{ e.ref }} image vision\n  uri: {{ e.slots.uploadUri }}\n  status: {{ e.slots.status }}\n  task: {{ e.slots.task }}\n  question: {{ e.slots.question }}\n  name: {{ e.slots.name }}\n  mime: {{ e.slots.mime }}\n  provider: {{ e.slots.providerModel }}\n  answer: {{ e.slots.answer }}\n  message: {{ e.slots.message }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}"
        }
      },
      "Search": {
        "Summary": "按 uploadUri 对用户上传图片、截图进行视觉识别、OCR 或问答。",
        "Keywords": [
          "image",
          "vision",
          "screenshot",
          "ocr",
          "uploadUri",
          "图片",
          "截图",
          "识图",
          "看图"
        ],
        "Capabilities": [
          {
            "Id": "image.vision",
            "Title": "Image vision",
            "Description": "Analyze an uploaded image by resolving uploadUri and routing it to the configured vision model.",
            "Facets": {
              "Actions": [
                "inspect",
                "describe",
                "ocr",
                "answer"
              ],
              "Targets": [
                "uploaded-image",
                "screenshot"
              ],
              "Inputs": [
                "upload-uri",
                "question",
                "task"
              ],
              "Outputs": [
                "visual-observations",
                "visible-text",
                "image-answer"
              ],
              "Evidence": [
                "image-vision-result"
              ],
              "Effects": [
                "model-call"
              ]
            },
            "Aliases": [
              "看图",
              "识别图片",
              "读取截图",
              "image OCR",
              "answer about this image"
            ],
            "Examples": [
              "看看这张截图里报错是什么",
              "识别这张图片里的文字",
              "What is shown in this uploaded image?"
            ],
            "Avoid": [
              "没有 uploadUri 时不要调用。",
              "非图片文件先用 DocumentTool 处理。"
            ],
            "Risk": {
              "SideEffect": "model-call",
              "Permission": "upload-read"
            }
          }
        ],
        "UseCases": [
          "用户上传截图、照片、UI 图片并要求描述、读取文字或回答图中问题。",
          "DocumentTool 探测到 mediaType=image 后，需要进一步理解图片内容。",
          "用户明确说“看图”“识别截图”“图里是什么”。"
        ],
        "Examples": [
          "看一下我上传的截图",
          "识别图片里的文字",
          "这张图里的 UI 有什么问题"
        ],
        "Avoid": [
          "不要对非图片附件直接调用；先探测文件类型。",
          "不要猜测 uploadUri。"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "External",
    "Network": "Allow",
    "FileSystem": {
      "Read": [
        ".senera/uploads"
      ],
      "Write": []
    },
    "RequiresApproval": false
  }
}
