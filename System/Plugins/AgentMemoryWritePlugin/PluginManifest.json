{
  "Plugin": {
    "Name": "AgentMemoryWritePlugin",
    "Title": "长期记忆写入",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Description": "把用户明确要求记住的内容直接写入 active 长期记忆。"
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 8
  },
  "Tools": [
    {
      "Name": "MemoryWriteTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [
        "memory:write"
      ],
      "Handler": {
        "Kind": "HostCapability",
        "Capability": "memory.write"
      },
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "memory_write",
            "Records": "$.memories.item[*]",
            "Slots": {
              "memoryUri": "$.memoryUri",
              "operation": "$.operation",
              "type": "$.type",
              "subject": "$.subject",
              "claim": "$.claim",
              "howToApply": "$.howToApply",
              "tags": "$.tags.item",
              "triggers": "$.triggers.item",
              "sourceRefs": "$.sourceRefs.item",
              "status": "$.status",
              "confidence": "$.confidence",
              "targetMemoryUri": "$.targetMemoryUri",
              "updatedAt": "$.updatedAt"
            },
            "Identity": {
              "Parts": [
                "memoryUri",
                "operation"
              ]
            },
            "Presentation": {
              "Locator": "{{ memoryUri }}",
              "Display": "{{ operation }} memory: {{ subject }}",
              "Label": "{{ subject }}",
              "Source": "{{ claim }}"
            },
            "Confidence": 0.9,
            "Metadata": {
              "operation": "$.operation",
              "type": "$.type",
              "targetMemoryUri": "$.targetMemoryUri"
            },
            "ModelProjection": {
              "Slots": [
                "memoryUri",
                "operation",
                "type",
                "subject",
                "claim",
                "howToApply",
                "tags",
                "triggers",
                "sourceRefs",
                "status",
                "confidence",
                "updatedAt"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "memoryUri",
                "operation",
                "type",
                "subject",
                "claim",
                "howToApply",
                "status"
              ],
              "ArtifactRefs": [
                "projection",
                "evidence"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.operation }} long-term memory {{ e.slots.subject }}: {{ e.slots.claim }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} memory write\n  uri: {{ e.slots.memoryUri }}\n  operation: {{ e.slots.operation }}\n  type: {{ e.slots.type }}\n  subject: {{ e.slots.subject }}\n  claim: {{ e.slots.claim }}\n  apply: {{ e.slots.howToApply }}\n  confidence: {{ e.slots.confidence }}\n  sourceRefs: {{ e.slots.sourceRefs }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}"
        }
      },
      "Search": {
        "Summary": "把用户明确要求记住的内容直接写入长期记忆。",
        "Capabilities": [
          {
            "Id": "memory.write",
            "Title": "长期记忆写入",
            "Description": "Write explicit user-requested memories directly into active long-term memory.",
            "Facets": {
              "Actions": [
                "write",
                "remember",
                "reinforce",
                "update",
                "supersede"
              ],
              "Targets": [
                "long-term-memory",
                "user-profile",
                "preference",
                "knowledge",
                "scene-state"
              ],
              "Inputs": [
                "explicit-memory",
                "memory-type",
                "memory-update"
              ],
              "Outputs": [
                "memory_write",
                "memory-item"
              ],
              "Evidence": [
                "memory_write"
              ],
              "Effects": [
                "persistent-write"
              ]
            },
            "Aliases": [
              "记住这个",
              "记录偏好",
              "以后都这样",
              "写入长期记忆"
            ],
            "Risk": {
              "SideEffect": "persistent-write",
              "Permission": "memory-write"
            }
          }
        ],
        "UseCases": [
          "用户明确要求记住偏好、画像、知识、设定或要求更新已有长期记忆。"
        ],
        "Examples": [
          "记住我喜欢无糖咖啡",
          "以后写代码不要硬编码",
          "把这个设定长期保存",
          "更新这条记忆"
        ],
        "Avoid": [
          "没有用户明确要求记住时不要调用。",
          "临时工具结果和普通任务结论不要直接写长期记忆。"
        ],
        "Tags": [
          "长期记忆",
          "记忆写入",
          "用户偏好",
          "用户画像",
          "知识"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "System",
    "Network": "Allow",
    "FileSystem": {
      "Read": [
        ".senera/Memory.sqlite",
        ".senera/Memory.sqlite-wal",
        ".senera/Memory.sqlite-shm"
      ],
      "Write": [
        ".senera/Memory.sqlite",
        ".senera/Memory.sqlite-wal",
        ".senera/Memory.sqlite-shm"
      ]
    },
    "RequiresApproval": false
  }
}
