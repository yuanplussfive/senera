{
  "Plugin": {
    "Name": "FastContextSearchToolPlugin",
    "Title": "工作区搜索",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Entry": {
      "Kind": "Process",
      "Command": "node",
      "Args": [
        "index.js"
      ],
      "Cwd": "."
    }
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 70
  },
  "Tools": [
    {
      "Name": "FastContextScoutTool",
      "DescriptionFile": "./docs/Scout.md",
      "SignatureFile": "./ToolSignature.ts",
      "SignatureType": "FastContextScoutToolArguments",
      "Handler": {
        "Kind": "HostCapability",
        "Capability": "workspace.context.scout"
      },
      "Permissions": [
        "filesystem:read:workspace",
        "filesystem:write:.state",
        "process:ripgrep"
      ],
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "workspace_scout_file",
            "Records": "$.files.item[*]",
            "Slots": {
              "path": "$.path",
              "startLine": "$.startLine",
              "endLine": "$.endLine",
              "totalLines": "$.totalLines",
              "score": "$.score",
              "reason": "$.reason",
              "focus": "$.focus",
              "content": "$.content"
            },
            "Identity": {
              "Parts": [
                "path",
                "startLine",
                "endLine"
              ]
            },
            "Presentation": {
              "Locator": "{{ path }}:{{ startLine }}-{{ endLine }}",
              "Display": "workspace context: {{ path }}:{{ startLine }}-{{ endLine }}",
              "Label": "{{ path }}",
              "Source": "{{ reason }}"
            },
            "Confidence": 0.88,
            "Metadata": {
              "score": "$.score",
              "totalLines": "$.totalLines",
              "reason": "$.reason",
              "focus": "$.focus"
            },
            "ModelProjection": {
              "Slots": [
                "path",
                "startLine",
                "endLine",
                "score",
                "reason",
                "focus",
                "content"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "path",
                "startLine",
                "endLine",
                "score",
                "reason",
                "focus"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.path }}:{{ e.slots.startLine }}-{{ e.slots.endLine }}{% if e.slots.focus %} focus: {{ e.slots.focus }}{% endif %} - {{ e.slots.reason }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} workspace context\n  path: {{ e.slots.path }}:{{ e.slots.startLine }}-{{ e.slots.endLine }}\n  score: {{ e.slots.score }}\n  reason: {{ e.slots.reason }}{% if e.slots.focus %}\n  focus: {{ e.slots.focus }}{% endif %}\n  content:\n{{ e.slots.content }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "本地工作区检索子代理：组合项目标记文件、路径匹配、ripgrep、索引和文件读取，返回最相关文件范围。",
        "Tags": [
          "项目定位",
          "上下文侦察",
          "文件发现",
          "配置查找",
          "工作区调查"
        ],
        "Capabilities": [
          {
            "Id": "workspace.context-scout",
            "Title": "Workspace context scout",
            "Description": "Run a local multi-stage workspace investigation and return concise source files with line ranges.",
            "Facets": {
              "Actions": [
                "investigate",
                "locate",
                "search",
                "read"
              ],
              "Targets": [
                "workspace",
                "source-code",
                "configuration",
                "documentation",
                "file"
              ],
              "Inputs": [
                "question",
                "hints",
                "workspace-root"
              ],
              "Outputs": [
                "source-location",
                "file-content",
                "context-packet",
                "line-range"
              ],
              "Evidence": [
                "workspace-scout-file"
              ],
              "Effects": [
                "read-only",
                "index-cache"
              ]
            },
            "Aliases": [
              "检索子代理",
              "上下文侦察",
              "find relevant files",
              "workspace scout"
            ],
            "Risk": {
              "SideEffect": "index-cache",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "项目配置、实现位置、关键文件、错误来源、UI 文案的本地定位。"
        ],
        "Examples": [
          "项目主模型配置文件",
          "模型供应商配置位置",
          "错误来源本地侦察",
          "model provider config file"
        ],
        "Avoid": [
          "已知道精确路径时用读取工具；只需要目录结构时用项目地图。"
        ]
      },
      "EvidenceCapabilities": [
        {
          "Produces": "workspace context packet",
          "Quality": "observed",
          "Satisfies": [
            "workspace investigation",
            "configuration source-of-truth",
            "implementation source-of-truth",
            "project file location"
          ],
          "Kinds": [
            "workspace_scout_file"
          ],
          "CapabilityIds": [
            "workspace.context-scout"
          ]
        }
      ]
    },
    {
      "Name": "FastContextHybridSearchTool",
      "DescriptionFile": "./docs/HybridSearch.md",
      "SignatureFile": "./ToolSignature.ts",
      "SignatureType": "FastContextHybridSearchToolArguments",
      "Permissions": [
        "filesystem:read:workspace",
        "filesystem:write:.state",
        "process:ripgrep"
      ],
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "workspace_search_match",
            "Records": "$.results.item[*]",
            "Slots": {
              "path": "$.path",
              "startLine": "$.startLine",
              "endLine": "$.endLine",
              "line": "$.line",
              "snippet": "$.snippet",
              "score": "$.score",
              "engine": "$.source",
              "reason": "$.reason",
              "focus": "$.focusSummary"
            },
            "Identity": {
              "Parts": [
                "path",
                "line",
                "engine"
              ]
            },
            "Presentation": {
              "Locator": "{{ path }}:{{ line }}",
              "Display": "{{ engine }} match in {{ path }}:{{ line }}",
              "Label": "{{ path }}",
              "Source": "{{ snippet }}"
            },
            "Confidence": 0.78,
            "Metadata": {
              "startLine": "$.startLine",
              "endLine": "$.endLine",
              "score": "$.score",
              "reason": "$.reason",
              "engine": "$.source"
            },
            "ModelProjection": {
              "Slots": [
                "path",
                "line",
                "startLine",
                "endLine",
                "snippet",
                "focus",
                "engine",
                "score",
                "reason"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "path",
                "line",
                "startLine",
                "endLine",
                "engine",
                "score",
                "reason",
                "focus"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.engine }} {{ e.slots.path }}:{{ e.slots.line }}{% if e.slots.focus %} focus: {{ e.slots.focus }}{% endif %} - {{ e.slots.snippet }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} workspace match\n  path: {{ e.slots.path }}:{{ e.slots.line }}\n  engine: {{ e.slots.engine }}\n  score: {{ e.slots.score }}\n  reason: {{ e.slots.reason }}{% if e.slots.focus %}\n  focus: {{ e.slots.focus }}{% endif %}\n  snippet: {{ e.slots.snippet }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "混合检索本地代码、路径、错误文本和相关上下文。",
        "Tags": [
          "混合检索",
          "代码搜索",
          "文本定位",
          "错误排查",
          "工作区调查"
        ],
        "Capabilities": [
          {
            "Id": "workspace.hybrid-search",
            "Title": "Workspace hybrid search",
            "Description": "Locate relevant source files from natural language, errors, paths, identifiers, and context clues.",
            "Facets": {
              "Actions": [
                "search",
                "locate",
                "inspect"
              ],
              "Targets": [
                "workspace",
                "source-code",
                "path",
                "error-text"
              ],
              "Inputs": [
                "query",
                "natural-language",
                "path",
                "identifier",
                "error-text"
              ],
              "Outputs": [
                "file-reference",
                "code-snippet",
                "match-list",
                "source-location"
              ],
              "Evidence": [
                "workspace-search-match"
              ],
              "Effects": [
                "read-only",
                "index-cache"
              ]
            },
            "Aliases": [
              "混合检索",
              "代码定位",
              "find related code",
              "search workspace context"
            ],
            "Risk": {
              "SideEffect": "index-cache",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "自然语言代码位置、Bug、UI 逻辑、错误文本的工作区定位。"
        ],
        "Examples": [
          "会话列表消息数量 前端代码",
          "XML 根标签多余文本处理",
          "requestId 实现定位",
          "streaming preview handling"
        ],
        "Avoid": [
          "已知道精确符号名时优先用符号搜索；已知道路径时用读取工具。"
        ]
      },
      "EvidenceCapabilities": [
        {
          "Produces": "workspace candidate",
          "Quality": "candidate",
          "Satisfies": [
            "candidate location",
            "workspace candidate location"
          ],
          "Kinds": [
            "workspace_search_match"
          ],
          "CapabilityIds": [
            "workspace.hybrid-search"
          ]
        }
      ]
    },
    {
      "Name": "FastContextSymbolSearchTool",
      "DescriptionFile": "./docs/SymbolSearch.md",
      "SignatureFile": "./ToolSignature.ts",
      "SignatureType": "FastContextSymbolSearchToolArguments",
      "Permissions": [
        "filesystem:read:workspace",
        "filesystem:write:.state"
      ],
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "workspace_symbol",
            "Records": "$.symbols.item[*]",
            "Slots": {
              "id": "$.id",
              "name": "$.name",
              "kind": "$.kind",
              "path": "$.path",
              "line": "$.line",
              "signature": "$.signature",
              "exported": "$.exported",
              "score": "$.score"
            },
            "Identity": {
              "Parts": [
                "id"
              ]
            },
            "Presentation": {
              "Locator": "{{ path }}:{{ line }}",
              "Display": "symbol definition: {{ name }} ({{ kind }})",
              "Label": "{{ name }}",
              "Source": "{{ signature }}"
            },
            "Confidence": 0.86,
            "Metadata": {
              "kind": "$.kind",
              "path": "$.path",
              "line": "$.line",
              "exported": "$.exported",
              "score": "$.score"
            },
            "ModelProjection": {
              "Slots": [
                "id",
                "name",
                "kind",
                "path",
                "line",
                "signature",
                "exported",
                "score"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "id",
                "name",
                "kind",
                "path",
                "line",
                "exported",
                "score"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.kind }} {{ e.slots.name }} @ {{ e.slots.path }}:{{ e.slots.line }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} symbol\n  name: {{ e.slots.name }}\n  kind: {{ e.slots.kind }}\n  path: {{ e.slots.path }}:{{ e.slots.line }}\n  signature: {{ e.slots.signature }}\n  exported: {{ e.slots.exported }}\n  score: {{ e.slots.score }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "按函数、类、类型、组件等符号名查找定义位置。",
        "Tags": [
          "符号查找",
          "定义定位",
          "代码结构",
          "组件查找"
        ],
        "Capabilities": [
          {
            "Id": "workspace.symbol-search",
            "Title": "Workspace symbol search",
            "Description": "Find definitions for functions, classes, types, components, constants, and exported symbols.",
            "Facets": {
              "Actions": [
                "search",
                "locate",
                "resolve"
              ],
              "Targets": [
                "symbol",
                "definition",
                "source-code",
                "workspace"
              ],
              "Inputs": [
                "symbol",
                "identifier",
                "function-name",
                "class-name",
                "component-name",
                "type-name"
              ],
              "Outputs": [
                "symbol-definition",
                "source-location",
                "signature",
                "file-reference"
              ],
              "Evidence": [
                "workspace-symbol"
              ],
              "Effects": [
                "read-only",
                "index-cache"
              ]
            },
            "Aliases": [
              "符号搜索",
              "找定义",
              "definition lookup",
              "where is this function"
            ],
            "Risk": {
              "SideEffect": "index-cache",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "知道函数名、类名、类型名、组件名或近似符号名，需要找定义时使用。"
        ],
        "Examples": [
          "createDecisionStreamingPreviewRules 定义",
          "AgentToolSearchIndex 类定义",
          "SessionList 组件定义",
          "parseToolCalls definition"
        ],
        "Avoid": [
          "自然语言问题或错误文本定位优先用混合搜索。"
        ]
      },
      "EvidenceCapabilities": [
        {
          "Produces": "workspace symbol",
          "Quality": "observed",
          "Satisfies": [
            "symbol definition",
            "implementation detail",
            "workspace source-of-truth",
            "workspace investigation"
          ],
          "Kinds": [
            "workspace_symbol"
          ],
          "CapabilityIds": [
            "workspace.symbol-search"
          ]
        }
      ]
    },
