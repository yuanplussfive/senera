{
  "ManifestVersion": 2,
  "Plugin": {
    "Name": "AgentDocumentPlugin",
    "Title": "文档处理",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Description": "按 uploadUri 统一处理上传文档：登记、探测 MIME/容器事实，并按配置选择内容抽取器生成正文、Markdown 预览和 chunks。"
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 8
  },
  "Tools": [
    {
      "Name": "DocumentTool",
      "Loading": "Dynamic",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": ["filesystem:read:uploads"],
      "Handler": {
        "Kind": "HostCapability",
        "Capability": "document"
      },
      "Execution": {
        "Boundary": "Local",
        "Network": "Deny",
        "Workspace": "ReadOnly",
        "LocalFallback": "Deny"
      },
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "uploaded_document",
            "Records": "$.documents.item[*]",
            "Slots": {
              "uploadUri": "$.uploadUri",
              "mode": "$.mode",
              "status": "$.status",
              "name": "$.name",
              "mime": "$.mime",
              "size": "$.size",
              "effectiveMime": "$.effectiveMime",
              "detectedMime": "$.detectedMime",
              "declaredMime": "$.declaredMime",
              "namedMime": "$.namedMime",
              "mediaType": "$.mediaType",
              "charset": "$.charset",
              "isText": "$.isText",
              "isBinary": "$.isBinary",
              "containerFormat": "$.containerFormat",
              "containerEntryCount": "$.containerEntryCount",
              "contentTypeDefaultCount": "$.contentTypeDefaultCount",
              "contentTypeOverrideCount": "$.contentTypeOverrideCount",
              "contentAvailable": "$.contentAvailable",
              "textAvailable": "$.textAvailable",
              "fileType": "$.fileType",
              "parser": "$.parser",
              "textLength": "$.textLength",
              "markdownLength": "$.markdownLength",
              "chunkCount": "$.chunkCount",
              "warningCount": "$.warningCount",
              "markdownPreview": "$.markdownPreview",
              "message": "$.message"
            },
            "Identity": {
              "Parts": ["uploadUri", "mode", "status"]
            },
            "Presentation": {
              "Locator": "{{ uploadUri }}",
              "Display": "document {{ status }}: {{ name }}",
              "Label": "{{ name }}",
              "Source": "{{ parser }}"
            },
            "Confidence": 0.9,
            "Metadata": {
              "status": "$.status",
              "mode": "$.mode",
              "effectiveMime": "$.effectiveMime",
              "mediaType": "$.mediaType",
              "fileType": "$.fileType",
              "parser": "$.parser",
              "textAvailable": "$.textAvailable",
              "chunkCount": "$.chunkCount"
            },
            "ModelProjection": {
              "Slots": [
                "uploadUri",
                "mode",
                "status",
                "name",
                "mime",
                "effectiveMime",
                "mediaType",
                "charset",
                "isText",
                "isBinary",
                "containerFormat",
                "containerEntryCount",
                "contentAvailable",
                "textAvailable",
                "fileType",
                "parser",
                "textLength",
                "markdownLength",
                "chunkCount",
                "warningCount",
                "markdownPreview",
                "message"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "uploadUri",
                "mode",
                "status",
                "name",
                "effectiveMime",
                "mediaType",
                "fileType",
                "parser",
                "textAvailable",
                "textLength",
                "chunkCount"
              ],
              "ArtifactRefs": ["projection"]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.status }} {{ e.slots.name }} mode={{ e.slots.mode }} mime={{ e.slots.effectiveMime }} fileType={{ e.slots.fileType }} text={{ e.slots.textLength }} chunks={{ e.slots.chunkCount }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} document\n  uri: {{ e.slots.uploadUri }}\n  mode: {{ e.slots.mode }}\n  status: {{ e.slots.status }}\n  name: {{ e.slots.name }}\n  storedMime: {{ e.slots.mime }}\n  effectiveMime: {{ e.slots.effectiveMime }}\n  detectedMime: {{ e.slots.detectedMime }}\n  declaredMime: {{ e.slots.declaredMime }}\n  namedMime: {{ e.slots.namedMime }}\n  mediaType: {{ e.slots.mediaType }}\n  charset: {{ e.slots.charset }}\n  isText: {{ e.slots.isText }}\n  isBinary: {{ e.slots.isBinary }}\n  containerFormat: {{ e.slots.containerFormat }}\n  containerEntryCount: {{ e.slots.containerEntryCount }}\n  contentTypeDefaults: {{ e.slots.contentTypeDefaultCount }}\n  contentTypeOverrides: {{ e.slots.contentTypeOverrideCount }}\n  contentAvailable: {{ e.slots.contentAvailable }}\n  textAvailable: {{ e.slots.textAvailable }}\n  fileType: {{ e.slots.fileType }}\n  parser: {{ e.slots.parser }}\n  textLength: {{ e.slots.textLength }}\n  markdownLength: {{ e.slots.markdownLength }}\n  chunkCount: {{ e.slots.chunkCount }}\n  warningCount: {{ e.slots.warningCount }}\n  markdownPreview: |\n{{ e.slots.markdownPreview }}\n  message: {{ e.slots.message }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}"
        }
      },
      "Search": {
        "Summary": "按 uploadUri 统一处理上传文档：探测文件事实，并通过配置化内容抽取器生成文本、Markdown 预览和 chunks。",
        "Capabilities": [
          {
            "Id": "document.process",
            "Title": "Document processing",
            "Description": "Resolve an uploadUri, probe file facts, and optionally extract content text and chunks through configured extractors.",
            "Facets": {
              "Actions": ["probe", "extract", "read", "summarize", "chunk"],
              "Targets": [
                "uploaded-document",
                "office-document",
                "text-document",
                "source-code",
                "log-file",
                "config-file",
                "pdf",
                "spreadsheet",
                "presentation",
                "upload-handle"
              ],
              "Inputs": ["upload-uri", "mode"],
              "Outputs": ["document-probe", "text-preview", "markdown-preview", "document-chunks", "metadata"],
              "Evidence": ["uploaded-document"],
              "Effects": ["read-only"]
            },
            "Aliases": [
              "读取文档",
              "处理附件",
              "抽取 PDF 内容",
              "读取 Word",
              "读取 Excel",
              "读取 PPT",
              "inspect uploaded document",
              "extract document text"
            ],
            "Risk": {
              "SideEffect": "read-only",
              "Permission": "upload-read"
            }
          }
        ],
        "UseCases": ["上传文件读取、总结、分析、要点提取。", "uploadUri、MIME 类型、编码、容器结构确认。"],
        "Examples": ["PDF 文档总结", "docx 上传文档读取", "附件 MIME 类型探测", "PPT 内容提取"],
        "Avoid": [
          "不要猜测 uploadUri。",
          "不要把 markdownPreview 当作完整全文；需要 textPreview 或 chunks 时读取 artifact 的 raw 引用。"
        ],
        "Tags": ["文档解析", "附件读取", "内容抽取", "文件预览", "格式识别"]
      },
      "Runtime": {
        "Lifecycle": "Immediate",
        "ProtocolVersion": 2,
        "Capabilities": {
          "Cancellation": true
        }
      }
    }
  ],
  "Security": {
    "TrustLevel": "Local",
    "Network": "Deny",
    "FileSystem": {
      "Read": [".senera/uploads"],
      "Write": []
    },
    "RequiresApproval": false
  }
}
