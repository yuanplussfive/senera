{
  "Plugin": {
    "Name": "AgentShellToolPlugin",
    "Title": "Host Shell Tool",
    "Version": "0.1.0",
    "Kind": "Tool"
  },
  "Discovery": {
    "Tags": [
      "shell",
      "终端",
      "command",
      "命令",
      "workspace",
      "工作区",
      "host",
      "构建",
      "测试"
    ]
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 90
  },
  "Tools": [
    {
      "Name": "ShellCommandTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [
        "process:shell",
        "filesystem:workspace"
      ],
      "Handler": {
        "Kind": "HostCapability",
        "Capability": "shell.run"
      },
      "Search": {
        "Summary": "在工作区内执行宿主机 shell 命令。",
        "Keywords": [
          "shell",
          "command",
          "terminal",
          "build",
          "test",
          "npm",
          "git",
          "命令",
          "终端",
          "执行",
          "构建",
          "测试",
          "检查"
        ],
        "UseCases": [
          "需要运行测试、构建、类型检查、git、脚本或系统命令时使用。"
        ],
        "Examples": [
          "运行 npm run check",
          "执行 git status",
          "查看 node --version",
          "run tests in Frontend"
        ],
        "Avoid": [
          "不要用于直接编辑文件；编辑文件使用 ApplyPatchTool。"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "System",
    "Network": "Allow",
    "FileSystem": {
      "Read": [
        "../.."
      ],
      "Write": [
        "../.."
      ]
    },
    "RequiresApproval": false
  }
}
