              "Display": "{{ engine }} match in {{ path }}:{{ line }}",
              "Label": "{{ path }}",
              "Source": "{{ snippet }}"
            },
            "Confidence": 0.82,
            "Metadata": {
              "startLine": "$.startLine",
              "endLine": "$.endLine",
              "score": "$.score",
              "reason": "$.reason",
              "engine": "$.source"
            },
            "ModelProjection": {
              "Slots": [
