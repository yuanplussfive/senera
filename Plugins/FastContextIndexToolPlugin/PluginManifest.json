{
  "Plugin": {
    "Name": "FastContextIndexToolPlugin",
    "Title": "工作区索引",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Entry": {
      "Kind": "Process",
      "Command": "node",
      "Args": [
        "index.js"
      ],
      "Cwd": "."
    }
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 71
  },
  "Tools": [
    {
      "Name": "FastContextIndexSearchTool",
      "DescriptionFile": "./docs/IndexSearch.md",
      "SignatureFile": "./ToolSignature.ts",
      "SignatureType": "FastContextIndexSearchToolArguments",
      "Permissions": [
        "filesystem:read:workspace",
        "filesystem:write:.state"
      ],
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "workspace_search_match",
            "Records": "$.results.item[*]",
            "Slots": {
              "path": "$.path",
              "startLine": "$.startLine",
              "endLine": "$.endLine",
              "line": "$.line",
              "snippet": "$.snippet",
              "score": "$.score",
              "engine": "$.source",
              "reason": "$.reason",
              "focus": "$.focusSummary"
            },
            "Identity": {
              "Parts": [
                "path",
                "line",
                "engine"
              ]
            },
            "Presentation": {
              "Locator": "{{ path }}:{{ line }}",
              "Display": "{{ engine }} match in {{ path }}:{{ line }}",
              "Label": "{{ path }}",
              "Source": "{{ snippet }}"
            },
            "Confidence": 0.76,
            "Metadata": {
              "startLine": "$.startLine",
              "endLine": "$.endLine",
              "score": "$.score",
              "reason": "$.reason",
              "engine": "$.source"
            },
            "ModelProjection": {
              "Slots": [
                "path",
                "line",
                "startLine",
                "endLine",
                "snippet",
                "focus",
                "engine",
                "score",
                "reason"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "path",
                "line",
                "startLine",
                "endLine",
                "engine",
                "score",
                "reason",
                "focus"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.engine }} {{ e.slots.path }}:{{ e.slots.line }}{% if e.slots.focus %} focus: {{ e.slots.focus }}{% endif %} - {{ e.slots.snippet }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} indexed match\n  path: {{ e.slots.path }}:{{ e.slots.line }}\n  engine: {{ e.slots.engine }}\n  score: {{ e.slots.score }}\n  reason: {{ e.slots.reason }}{% if e.slots.focus %}\n  focus: {{ e.slots.focus }}{% endif %}\n  snippet: {{ e.slots.snippet }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "使用本地 SQLite FTS5/trigram 索引快速搜索代码、路径和文本片段。",
        "Tags": [
          "工作区检索",
          "代码搜索",
          "索引查询",
          "本地缓存"
        ],
        "Capabilities": [
          {
            "Id": "workspace.index-search",
            "Title": "Workspace index search",
            "Description": "Search previously indexed workspace documents, code, paths, and symbol text with low latency.",
            "Facets": {
              "Actions": [
                "search",
                "locate",
                "inspect"
              ],
              "Targets": [
                "workspace-index",
                "workspace",
                "source-code",
                "path"
              ],
              "Inputs": [
                "query",
                "keyword",
                "path",
                "symbol"
              ],
              "Outputs": [
                "file-reference",
                "code-snippet",
                "match-list"
              ],
              "Evidence": [
                "workspace-search-match"
              ],
              "Effects": [
                "read-only",
                "uses-cache"
              ]
            },
            "Aliases": [
              "索引搜索",
              "本地检索",
              "cached workspace search",
              "fast code search"
            ],
            "Risk": {
              "SideEffect": "none",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "需要低成本、快速地从已索引工作区里查找相关代码或文件时使用。"
        ],
        "Examples": [
          "索引检索 AgentLoop",
          "前端删除会话逻辑 索引",
          "tool registry indexed workspace search",
          "cached code search"
        ],
        "Avoid": [
          "需要最新未索引内容时先刷新索引或使用精确搜索。"
        ]
      },
      "EvidenceCapabilities": [
        {
          "Produces": "workspace candidate",
          "Quality": "candidate",
          "Satisfies": [
            "candidate location",
            "workspace candidate location"
          ],
          "Kinds": [
            "workspace_search_match"
          ],
          "CapabilityIds": [
            "workspace.index-search"
          ]
        }
      ]
    },
    {
      "Name": "FastContextRefreshIndexTool",
      "DescriptionFile": "./docs/RefreshIndex.md",
      "SignatureFile": "./ToolSignature.ts",
      "SignatureType": "FastContextRefreshIndexToolArguments",
      "Permissions": [
        "filesystem:read:workspace",
        "filesystem:write:.state"
      ],
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "workspace_index",
            "Records": "$",
            "Slots": {
              "workspaceRoot": "$.workspaceRoot",
              "stateFile": "$.stateFile",
              "indexedFiles": "$.indexedFiles",
              "indexedDocuments": "$.indexedDocuments",
              "indexedSymbols": "$.indexedSymbols",
              "skippedFiles": "$.skippedFiles",
              "elapsedMs": "$.elapsedMs"
            },
            "Identity": {
              "Parts": [
                "workspaceRoot",
                "stateFile"
              ]
            },
            "Presentation": {
              "Locator": "{{ stateFile }}",
              "Display": "workspace index refreshed: {{ indexedFiles }} files, {{ indexedSymbols }} symbols",
              "Label": "{{ workspaceRoot }}",
              "Source": "{{ stateFile }}"
            },
            "Confidence": 0.88,
            "Metadata": {
              "indexedFiles": "$.indexedFiles",
              "indexedDocuments": "$.indexedDocuments",
              "indexedSymbols": "$.indexedSymbols",
              "skippedFiles": "$.skippedFiles",
              "elapsedMs": "$.elapsedMs"
            },
            "ModelProjection": {
              "Slots": [
                "workspaceRoot",
                "stateFile",
                "indexedFiles",
                "indexedDocuments",
                "indexedSymbols",
                "skippedFiles",
                "elapsedMs"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "workspaceRoot",
                "stateFile",
                "indexedFiles",
                "indexedDocuments",
                "indexedSymbols",
                "skippedFiles",
                "elapsedMs"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} index refreshed: {{ e.slots.indexedFiles }} files, {{ e.slots.indexedSymbols }} symbols\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} workspace index\n  root: {{ e.slots.workspaceRoot }}\n  state: {{ e.slots.stateFile }}\n  files: {{ e.slots.indexedFiles }}\n  documents: {{ e.slots.indexedDocuments }}\n  symbols: {{ e.slots.indexedSymbols }}\n  skipped: {{ e.slots.skippedFiles }}\n  elapsedMs: {{ e.slots.elapsedMs }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "刷新或重建本地代码检索索引。",
        "Tags": [
          "工作区索引",
          "缓存刷新",
          "项目扫描",
          "代码检索"
        ],
        "Capabilities": [
          {
            "Id": "workspace.index-refresh",
            "Title": "Workspace index refresh",
            "Description": "Refresh or rebuild the local workspace search index after file changes or stale search results.",
            "Facets": {
              "Actions": [
                "refresh",
                "rebuild",
                "index"
              ],
              "Targets": [
                "workspace-index",
                "workspace-cache",
                "source-code"
              ],
              "Inputs": [
                "workspace-root",
                "path"
              ],
              "Outputs": [
                "index-summary",
                "cache-state",
                "indexed-file-count"
              ],
              "Evidence": [
                "workspace-index"
              ],
              "Effects": [
                "write-cache"
              ]
            },
            "Aliases": [
              "刷新索引",
              "重建缓存",
              "refresh index",
              "reindex workspace"
            ],
            "Risk": {
              "SideEffect": "write-cache",
              "Permission": "read-write-cache"
            }
          }
        ],
        "UseCases": [
          "代码刚改动、索引结果过期或需要强制重建检索缓存时使用。"
        ],
        "Examples": [
          "刷新工作区代码索引",
          "重建本地检索缓存",
          "refresh fast context index",
          "reindex workspace files"
        ],
        "Avoid": [
          "只是读取文件或搜索一个字符串时不需要刷新索引。"
        ]
      },
      "EvidenceCapabilities": [
        {
          "Produces": "workspace index",
          "Quality": "observed",
          "Satisfies": [
            "index freshness"
          ],
          "Kinds": [
            "workspace_index"
          ],
          "CapabilityIds": [
            "workspace.index-refresh"
          ]
        }
      ]
    }
  ],
  "Security": {
    "TrustLevel": "Local",
    "Network": "Deny",
    "FileSystem": {
      "Read": [
        "../.."
      ],
      "Write": [
        ".state"
      ]
    },
    "RequiresApproval": false
  }
}
