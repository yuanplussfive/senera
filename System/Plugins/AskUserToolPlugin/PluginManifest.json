{
  "Plugin": {
    "Name": "AskUserToolPlugin",
    "Title": "询问用户",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Entry": {
      "Kind": "Process",
      "Command": "node",
      "Args": [
        "index.js"
      ],
      "Cwd": "."
    }
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 20
  },
  "Tools": [
    {
      "Name": "AskUserTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [],
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "clarification_request",
            "Records": "$.control",
            "Slots": {
              "kind": "$.kind",
              "question": "$.question",
              "reasonCode": "$.reason_code"
            },
            "Identity": {
              "Parts": [
                "question",
                {
                  "Slot": "reasonCode",
                  "Required": false
                }
              ]
            },
            "Presentation": {
              "Locator": "{% if reasonCode != blank %}{{ reasonCode }}{% else %}clarification{% endif %}",
              "Display": "clarification requested: {{ question }}",
              "Label": "{{ question }}",
              "Source": "{% if reasonCode != blank %}{{ reasonCode }}{% else %}missing_information{% endif %}"
            },
            "Confidence": 0.9,
            "Metadata": {
              "reasonCode": "$.reason_code"
            },
            "ModelProjection": {
              "Slots": [
                "question",
                "reasonCode"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "question",
                "reasonCode"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} ask user: {{ e.slots.question }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} clarification request\n  question: {{ e.slots.question }}\n  reason: {{ e.slots.reasonCode }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "向用户提出一个简短澄清问题，等待用户补充关键信息。",
        "Tags": [
          "用户确认",
          "信息补充",
          "问题澄清",
          "选择决策"
        ],
        "Capabilities": [
          {
            "Id": "conversation.ask-user",
            "Title": "Ask user",
            "Description": "Ask the user for missing essential information, confirmation, or disambiguation.",
            "Facets": {
              "Actions": [
                "ask",
                "clarify",
                "confirm"
              ],
              "Targets": [
                "user",
                "conversation",
                "missing-information"
              ],
              "Inputs": [
                "question",
                "reason-code"
              ],
              "Outputs": [
                "clarification-request",
                "user-question"
              ],
              "Evidence": [
                "clarification-request"
              ],
              "Effects": [
                "blocks-run",
                "user-visible"
              ]
            },
            "Aliases": [
              "问用户",
              "澄清问题",
              "ask for clarification",
              "confirm with user"
            ],
            "Risk": {
              "SideEffect": "user-visible",
              "Permission": "none"
            }
          }
        ],
        "UseCases": [
          "缺少必要参数、目标不明确或继续执行有歧义时使用。"
        ],
        "Examples": [
          "缺少搜索关键词确认",
          "删除目标二次确认",
          "ask user for missing location",
          "ambiguous required parameter"
        ],
        "Avoid": [
          "如果已经可以直接回答或直接调用工具，不要再询问用户。"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "Local",
    "Network": "Deny",
    "FileSystem": {
      "Read": [],
      "Write": []
    },
    "RequiresApproval": false
  }
}
