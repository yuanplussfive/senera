{
  "Plugin": {
    "Name": "AgentArtifactMemoryPlugin",
    "Title": "Artifact Memory Reader",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Description": "Loads persisted artifact memories by canonical artifact URI."
  },
  "Discovery": {
    "Tags": [
      "artifact",
      "memory",
      "evidence",
      "projection",
      "记忆",
      "证据",
      "产物",
      "读取"
    ]
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 8
  },
  "Tools": [
    {
      "Name": "ArtifactMemoryReadTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [
        "filesystem:read:artifacts"
      ],
      "Handler": {
        "Kind": "HostCapability",
        "Capability": "artifact.memory.read"
      },
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "artifact_memory",
            "Records": "$.artifacts.item[*]",
            "Slots": {
              "artifactUri": "$.artifactUri",
              "artifactId": "$.artifactId",
              "status": "$.status",
              "message": "$.message",
              "availableRefCount": "$.availableRefCount",
              "memoryCount": "$.memoryCount"
            },
            "Identity": {
              "Parts": [
                "artifactUri",
                "status"
              ]
            },
            "Presentation": {
              "RefPrefix": "ART",
              "Locator": "{{ artifactUri }}",
              "Display": "artifact memory {{ status }}: {{ artifactUri }}",
              "Label": "{{ artifactUri }}",
              "Source": "{{ message }}"
            },
            "Confidence": 0.9,
            "Metadata": {
              "status": "$.status",
              "availableRefCount": "$.availableRefCount",
              "memoryCount": "$.memoryCount"
            },
            "ModelProjection": {
              "Slots": [
                "artifactUri",
                "artifactId",
                "status",
                "message",
                "availableRefCount",
                "memoryCount"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "artifactUri",
                "artifactId",
                "status",
                "availableRefCount",
                "memoryCount"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- {{ e.ref }} {{ e.slots.status }} {{ e.slots.artifactUri }} (loaded {{ e.slots.memoryCount }} refs)\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- {{ e.ref }} artifact memory\n  uri: {{ e.slots.artifactUri }}\n  status: {{ e.slots.status }}\n  availableRefs: {{ e.slots.availableRefCount }}\n  loadedRefs: {{ e.slots.memoryCount }}\n  message: {{ e.slots.message }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "按 artifactUri 读取已经落地的 artifact 记忆和证据投影。",
        "Keywords": [
          "artifact",
          "memory",
          "evidence",
          "projection",
          "read",
          "hydrate",
          "记忆",
          "证据",
          "读取",
          "展开"
        ],
        "Capabilities": [
          {
            "Id": "artifact.memory-read",
            "Title": "Artifact memory read",
            "Description": "Load persisted artifact projections or evidence records by canonical artifact URI.",
            "Facets": {
              "Actions": [
                "read",
                "hydrate",
                "inspect"
              ],
              "Targets": [
                "artifact-memory",
                "artifact-projection",
                "artifact-evidence"
              ],
              "Inputs": [
                "artifact-uri",
                "artifact-uri-list",
                "artifact-ref"
              ],
              "Outputs": [
                "artifact-memory",
                "projection-text",
                "evidence-json"
              ],
              "Evidence": [
                "artifact-memory"
              ],
              "Effects": [
                "read-only"
              ]
            },
            "Aliases": [
              "读取记忆",
              "展开证据",
              "load artifact memory",
              "hydrate artifact evidence"
            ],
            "Examples": [
              "读取 artifactUri 对应的 projection",
              "load evidence for two artifact URIs"
            ],
            "Avoid": [
              "当前 timeline 已经包含足够证据时不要重复读取。"
            ],
            "Risk": {
              "SideEffect": "read-only",
              "Permission": "artifact-read"
            }
          }
        ],
        "UseCases": [
          "evidenceMemory 只有轻量 facts，但回答需要完整 projection 或 evidence 时使用。",
          "用户追问之前搜索、网页或工具结果的具体内容时使用。",
          "需要按 artifactUri 批量展开多个历史证据包时使用。"
        ],
        "Examples": [
          "读取 senera://artifact/art_1234567890abcdef12345678",
          "把这两个 artifactUri 的 projection 取出来",
          "需要 evidence.json 中的结构化记录"
        ],
        "Avoid": [
          "artifactUri 缺失时先使用当前上下文或检索工具定位证据引用。",
          "只需要轻量 facts 就能回答时不要读取完整 artifact。"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "System",
    "Network": "Deny",
    "FileSystem": {
      "Read": [
        ".senera/artifacts"
      ],
      "Write": []
    },
    "RequiresApproval": false
  }
}
