{
  "Plugin": {
    "Name": "FastContextSearchToolPlugin",
    "Title": "工作区搜索",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Entry": {
      "Kind": "Process",
      "Command": "node",
      "Args": [
        "index.js"
      ],
      "Cwd": "."
    }
  },
  "Discovery": {
    "Tags": [
      "context",
      "上下文",
      "search",
      "搜索",
      "ripgrep",
      "hybrid",
      "symbol",
      "workspace",
      "工作区",
      "代码",
      "符号",
      "定位"
    ]
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 70
  },
  "Tools": [
    {
      "Name": "FastContextHybridSearchTool",
      "DescriptionFile": "./docs/HybridSearch.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [
        "filesystem:read:workspace",
        "filesystem:write:.state",
        "process:ripgrep"
      ],
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "workspace_search_match",
            "Records": "$.results.item[*]",
            "Slots": {
              "path": "$.path",
              "startLine": "$.startLine",
              "endLine": "$.endLine",
              "line": "$.line",
              "snippet": "$.snippet",
              "score": "$.score",
              "engine": "$.source",
              "reason": "$.reason",
              "focus": "$.focusSummary"
            },
            "Identity": {
              "Parts": [
                "path",
                "line",
                "engine"
              ]
            },
            "Presentation": {
              "RefPrefix": "S",
              "Locator": "{{ path }}:{{ line }}",
              "Display": "{{ engine }} match in {{ path }}:{{ line }}",
              "Label": "{{ path }}",
              "Source": "{{ snippet }}"
            },
            "Confidence": 0.78,
            "Metadata": {
              "startLine": "$.startLine",
              "endLine": "$.endLine",
              "score": "$.score",
              "reason": "$.reason",
              "engine": "$.source"
            },
            "ModelProjection": {
              "Slots": [
                "path",
                "line",
                "startLine",
                "endLine",
                "snippet",
                "focus",
                "engine",
                "score",
                "reason"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "path",
                "line",
                "startLine",
                "endLine",
                "engine",
                "score",
                "reason",
                "focus"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- {{ e.ref }} {{ e.slots.engine }} {{ e.slots.path }}:{{ e.slots.line }}{% if e.slots.focus %} focus: {{ e.slots.focus }}{% endif %} - {{ e.slots.snippet }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- {{ e.ref }} workspace match\n  path: {{ e.slots.path }}:{{ e.slots.line }}\n  engine: {{ e.slots.engine }}\n  score: {{ e.slots.score }}\n  reason: {{ e.slots.reason }}{% if e.slots.focus %}\n  focus: {{ e.slots.focus }}{% endif %}\n  snippet: {{ e.slots.snippet }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "混合检索本地代码、路径、错误文本和相关上下文。",
        "Keywords": [
          "hybrid",
          "search",
          "code",
          "context",
          "ripgrep",
          "index",
          "workspace",
          "混合检索",
          "代码搜索",
          "上下文",
          "定位",
          "错误文本",
          "前端",
          "后端"
        ],
        "Capabilities": [
          {
            "Id": "workspace.hybrid-search",
            "Title": "Workspace hybrid search",
            "Description": "Locate relevant source files from natural language, errors, paths, identifiers, and context clues.",
            "Facets": {
              "Actions": [
                "search",
                "locate",
                "inspect"
              ],
              "Targets": [
                "workspace",
                "source-code",
                "path",
                "error-text"
              ],
              "Inputs": [
                "query",
                "natural-language",
                "path",
                "identifier",
                "error-text"
              ],
              "Outputs": [
                "file-reference",
                "code-snippet",
                "match-list",
                "source-location"
              ],
              "Evidence": [
                "workspace-search-match"
              ],
              "Effects": [
                "read-only",
                "index-cache"
              ]
            },
            "Aliases": [
              "混合检索",
              "代码定位",
              "find related code",
              "search workspace context"
            ],
            "Examples": [
              "定位左侧会话列表消息数量不更新的前端代码",
              "find code handling streaming preview"
            ],
            "Avoid": [
              "已知道精确符号名时优先用符号搜索；已知道路径时用读取工具"
            ],
            "Risk": {
              "SideEffect": "index-cache",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "用户用自然语言描述代码位置、Bug、UI 逻辑或错误文本，需要在本地项目里定位相关文件时使用。"
        ],
        "Examples": [
          "定位左侧会话列表消息数量不更新的前端代码",
          "找 XML 根标签前存在多余文本的处理逻辑",
          "搜索 requestId 相关实现",
          "find code handling streaming preview"
        ],
        "Avoid": [
          "已知道精确符号名时优先用符号搜索；已知道路径时用读取工具。"
        ]
      },
      "EvidenceCapabilities": [
        {
          "Produces": "workspace candidate",
          "Quality": "candidate",
          "Satisfies": [
            "candidate location",
            "workspace candidate location"
          ],
          "Kinds": [
            "workspace_search_match"
          ],
          "CapabilityIds": [
            "workspace.hybrid-search"
          ]
        }
      ]
    },
    {
      "Name": "FastContextSymbolSearchTool",
      "DescriptionFile": "./docs/SymbolSearch.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [
        "filesystem:read:workspace",
        "filesystem:write:.state"
      ],
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "workspace_symbol",
            "Records": "$.symbols.item[*]",
            "Slots": {
              "id": "$.id",
              "name": "$.name",
              "kind": "$.kind",
              "path": "$.path",
              "line": "$.line",
              "signature": "$.signature",
              "exported": "$.exported",
              "score": "$.score"
            },
            "Identity": {
              "Parts": [
                "id"
              ]
            },
            "Presentation": {
              "RefPrefix": "SYM",
              "Locator": "{{ path }}:{{ line }}",
              "Display": "symbol definition: {{ name }} ({{ kind }})",
              "Label": "{{ name }}",
              "Source": "{{ signature }}"
            },
            "Confidence": 0.86,
            "Metadata": {
              "kind": "$.kind",
              "path": "$.path",
              "line": "$.line",
              "exported": "$.exported",
              "score": "$.score"
            },
            "ModelProjection": {
              "Slots": [
                "id",
                "name",
                "kind",
                "path",
                "line",
                "signature",
                "exported",
                "score"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "id",
                "name",
                "kind",
                "path",
                "line",
                "exported",
                "score"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- {{ e.ref }} {{ e.slots.kind }} {{ e.slots.name }} @ {{ e.slots.path }}:{{ e.slots.line }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- {{ e.ref }} symbol\n  name: {{ e.slots.name }}\n  kind: {{ e.slots.kind }}\n  path: {{ e.slots.path }}:{{ e.slots.line }}\n  signature: {{ e.slots.signature }}\n  exported: {{ e.slots.exported }}\n  score: {{ e.slots.score }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "按函数、类、类型、组件等符号名查找定义位置。",
        "Keywords": [
          "symbol",
          "definition",
          "function",
          "class",
          "type",
          "component",
          "符号",
          "定义",
          "函数",
          "类",
          "类型",
          "组件",
          "声明"
        ],
        "Capabilities": [
          {
            "Id": "workspace.symbol-search",
            "Title": "Workspace symbol search",
            "Description": "Find definitions for functions, classes, types, components, constants, and exported symbols.",
            "Facets": {
              "Actions": [
                "search",
                "locate",
                "resolve"
              ],
              "Targets": [
                "symbol",
                "definition",
                "source-code",
                "workspace"
              ],
              "Inputs": [
                "symbol",
                "identifier",
                "function-name",
                "class-name",
                "component-name",
                "type-name"
              ],
              "Outputs": [
                "symbol-definition",
                "source-location",
                "signature",
                "file-reference"
              ],
              "Evidence": [
                "workspace-symbol"
              ],
              "Effects": [
                "read-only",
                "index-cache"
              ]
            },
            "Aliases": [
              "符号搜索",
              "找定义",
              "definition lookup",
              "where is this function"
            ],
            "Examples": [
              "找 AgentToolSearchIndex 类",
              "where is parseToolCalls defined"
            ],
            "Avoid": [
              "自然语言问题或错误文本定位优先用混合搜索"
            ],
            "Risk": {
              "SideEffect": "index-cache",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "知道函数名、类名、类型名、组件名或近似符号名，需要找定义时使用。"
        ],
        "Examples": [
          "函数名 createDecisionStreamingPreviewRules 找定义",
          "找 AgentToolSearchIndex 类",
          "查 SessionList 组件定义",
          "where is parseToolCalls defined"
        ],
        "Avoid": [
          "自然语言问题或错误文本定位优先用混合搜索。"
        ]
      },
      "EvidenceCapabilities": [
        {
          "Produces": "workspace symbol",
          "Quality": "observed",
          "Satisfies": [
            "symbol definition",
            "implementation detail",
            "workspace source-of-truth",
            "workspace investigation"
          ],
          "Kinds": [
            "workspace_symbol"
          ],
          "CapabilityIds": [
            "workspace.symbol-search"
          ]
        }
      ]
    },
    {
      "Name": "FastContextSearchTool",
      "DescriptionFile": "./docs/ExactSearch.md",
