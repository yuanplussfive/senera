              "ArtifactTemplate": "{% for e in evidence %}- {{ e.ref }} workspace match\n  path: {{ e.slots.path }}:{{ e.slots.line }}\n  engine: {{ e.slots.engine }}\n  score: {{ e.slots.score }}\n  reason: {{ e.slots.reason }}{% if e.slots.focus %}\n  focus: {{ e.slots.focus }}{% endif %}\n  snippet: {{ e.slots.snippet }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "使用 ripgrep 精确搜索本地文本、标识符、路径片段或正则。",
        "Keywords": [
          "ripgrep",
          "grep",
          "exact",
          "regex",
          "text",
          "identifier",
          "精确搜索",
          "文本搜索",
          "正则",
          "标识符",
          "代码搜索"
        ],
        "Capabilities": [
          {
            "Id": "workspace.exact-search",
            "Title": "Workspace exact search",
            "Description": "Run exact text, identifier, path-fragment, or regular-expression search over workspace files.",
            "Facets": {
              "Actions": [
                "search",
                "grep",
                "locate"
              ],
              "Targets": [
                "workspace",
                "source-code",
                "text",
                "path"
              ],
              "Inputs": [
                "query",
                "exact-text",
                "identifier",
                "regex",
                "path-fragment"
              ],
              "Outputs": [
                "file-reference",
                "code-snippet",
                "match-list",
                "source-location"
              ],
              "Evidence": [
                "workspace-search-match"
              ],
              "Effects": [
                "read-only"
              ]
            },
            "Aliases": [
              "精确搜索",
              "文本搜索",
              "ripgrep",
              "grep workspace"
            ],
            "Examples": [
              "搜索 IncompleteXmlEnvelope",
              "find exact string MaxOutputTokens"
            ],
            "Avoid": [
              "抽象代码定位优先用混合搜索；符号定义优先用符号搜索"
            ],
            "Risk": {
              "SideEffect": "none",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "用户给出明确字符串、错误码、XML 标签、变量名或正则表达式，需要快速精确搜索时使用。"
        ],
        "Examples": [
          "搜索 IncompleteXmlEnvelope",
          "rg senera_tool_calls",
          "查找 messageCount 字符串",
          "find exact string MaxOutputTokens"
        ],
        "Avoid": [
          "抽象代码定位优先用混合搜索；符号定义优先用符号搜索。"
        ]
      },
      "EvidenceCapabilities": [
        {
          "Produces": "workspace candidate",
          "Quality": "candidate",
          "Satisfies": [
            "candidate location",
            "workspace candidate location"
          ],
          "Kinds": [
            "workspace_search_match"
          ],
          "CapabilityIds": [
            "workspace.exact-search"
          ]
        }
      ]
    }
  ],
  "Security": {
    "TrustLevel": "Local",
    "Network": "Deny",
    "FileSystem": {
      "Read": [
        "../.."
      ],
      "Write": [
        ".state"
      ]
    },
    "RequiresApproval": false
  }
}
