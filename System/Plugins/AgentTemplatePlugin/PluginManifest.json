{
  "Plugin": {
    "Name": "AgentTemplatePlugin",
    "Title": "Agent Prompt Templates",
    "Version": "0.1.0",
    "Kind": "System",
    "Description": "提供面向模型的基础 Liquid 提示词模板。"
  },
  "Templates": [
    {
      "Name": "BaseSystemPrompt",
      "Path": "./Templates/BaseSystemPrompt.liquid"
    },
    {
      "Name": "RepairPrompt",
      "Path": "./Templates/RepairPrompt.liquid"
    },
    {
      "Name": "ActionMismatchRepairPrompt",
      "Path": "./Templates/ActionMismatchRepairPrompt.liquid"
    },
    {
      "Name": "PromptGuidance",
      "Path": "./Templates/PromptGuidance.liquid"
    },
    {
      "Name": "DecisionProtocol",
      "Path": "./Templates/DecisionProtocol.liquid"
    },
    {
      "Name": "RootCommand",
      "Path": "./Templates/RootCommand.liquid"
    },
    {
      "Name": "ToolCatalog",
      "Path": "./Templates/ToolCatalog.liquid"
    },
    {
      "Name": "SkillCatalog",
      "Path": "./Templates/SkillCatalog.liquid"
    },
    {
      "Name": "ChildAgentSystemPrompt",
      "Path": "./Templates/ChildAgentSystemPrompt.liquid"
    },
    {
      "Name": "AgentMergeSystemPrompt",
      "Path": "./Templates/AgentMergeSystemPrompt.liquid"
    }
  ],
  "RootCommands": [
    {
      "Action": "answer",
      "OutputMode": "final_text",
      "ToolAccess": "disabled",
      "Objective": "直接回答最新用户请求。",
      "InsufficiencyPolicy": "如果当前上下文不足以确认事实，直接说明无法从现有上下文确认，不要调用工具。",
      "AllowedTools": [
        {
          "Source": "None"
        }
      ],
      "ForbiddenOutputs": [
        "senera_tool_calls",
        "tool_call_xml",
        "internal_context_xml"
      ],
      "VisibleOutput": {
        "Audience": "user",
        "Start": "answer_body",
        "Format": "final_text",
        "Rules": [
          {
            "Name": "meta_speech",
            "Value": "forbidden",
            "Instruction": "不要用确认句、寒暄、执行声明或“我会直接回答”开头。"
          },
          {
            "Name": "acknowledge_instruction",
            "Value": "forbidden",
            "Instruction": "不要向用户确认你正在遵守本轮指令。"
          },
          {
            "Name": "mention_runtime_control",
            "Value": "forbidden",
            "Instruction": "不要提到 RootCommand、输出模式、修复流程、校验器或内部协议。"
          },
          {
            "Name": "first_sentence",
            "Value": "answer_body",
            "Instruction": "首句必须回答用户问题本身。"
          }
        ],
        "Repair": {
          "Instruction": "只输出可直接展示给用户的答案正文；不要确认修复，不要解释输出模式，不要提到工具策略或内部控制。",
          "Rules": [
            {
              "Name": "start",
              "Value": "answer_body",
              "Instruction": "从答案正文第一句开始。"
            },
            {
              "Name": "meta_speech",
              "Value": "forbidden",
              "Instruction": "不要输出“好的”“我将”“我直接回答”等元话语。"
            }
          ]
        }
      },
      "IncludeDecisionProtocol": false,
      "IncludeToolCatalog": false
    },
    {
      "Action": "ask_user",
      "OutputMode": "tool_call_xml",
      "ToolAccess": "restricted",
      "Objective": "向用户提出继续任务所必需的问题。",
      "InsufficiencyPolicy": "只通过允许的提问工具请求必要信息，不要自行补全关键缺失事实。",
      "AllowedTools": [
        {
          "Source": "NamedLoaded",
          "Names": [
            "AskUserTool"
          ]
        }
      ],
      "ForbiddenOutputs": [
        "final_answer",
        "unregistered_tools"
      ],
      "VisibleOutput": {
        "Audience": "runtime",
        "Start": "tool_call_xml_root",
        "Format": "tool_call_xml",
        "Rules": [
          {
            "Name": "natural_language",
            "Value": "forbidden",
            "Instruction": "不要输出解释、寒暄、标题或 Markdown。"
          },
          {
            "Name": "root",
            "Value": "tool_call_xml_root",
            "Instruction": "第一个非空字符必须是 <，并且只输出一个完整工具调用根。"
          },
          {
            "Name": "tool_name_source",
            "Value": "allowed_tools",
            "Instruction": "工具名只能来自 allowed_tools。"
          }
        ],
        "Repair": {
          "Instruction": "只输出完整工具调用 XML；不要解释，不要确认修复，不要回答用户。",
          "Rules": [
            {
              "Name": "start",
              "Value": "tool_call_xml_root",
              "Instruction": "第一个非空字符必须是 <。"
            },
            {
              "Name": "natural_language",
              "Value": "forbidden",
              "Instruction": "XML 外不能有自然语言、Markdown、标题、代码围栏或解释。"
            }
          ]
        }
      },
      "IncludeDecisionProtocol": true,
      "IncludeToolCatalog": true
    },
    {
      "Action": "discover_tools",
      "OutputMode": "tool_call_xml",
      "ToolAccess": "discovery_only",
      "Objective": "搜索当前任务需要的插件能力。",
      "InsufficiencyPolicy": "只调用工具发现能力，不要猜测未展示的工具名。",
      "AllowedTools": [
        {
          "Source": "HostCapability",
          "Capability": "tool.search"
        }
      ],
      "ForbiddenOutputs": [
        "final_answer",
        "business_tool_calls",
        "unregistered_tools"
      ],
      "VisibleOutput": {
        "Audience": "runtime",
        "Start": "tool_call_xml_root",
        "Format": "tool_call_xml",
        "Rules": [
          {
            "Name": "natural_language",
            "Value": "forbidden",
            "Instruction": "不要输出解释、寒暄、标题或 Markdown。"
          },
          {
            "Name": "root",
            "Value": "tool_call_xml_root",
            "Instruction": "第一个非空字符必须是 <，并且只输出一个完整工具调用根。"
          },
          {
            "Name": "tool_name_source",
            "Value": "allowed_tools",
            "Instruction": "工具名只能来自 allowed_tools。"
          }
        ],
        "Repair": {
          "Instruction": "只输出完整工具调用 XML；不要解释，不要确认修复，不要回答用户。",
          "Rules": [
            {
              "Name": "start",
              "Value": "tool_call_xml_root",
              "Instruction": "第一个非空字符必须是 <。"
            },
            {
              "Name": "natural_language",
              "Value": "forbidden",
              "Instruction": "XML 外不能有自然语言、Markdown、标题、代码围栏或解释。"
            }
          ]
        }
      },
      "IncludeDecisionProtocol": true,
      "IncludeToolCatalog": true
    },
    {
      "Action": "use_tools",
      "OutputMode": "tool_call_xml",
      "ToolAccess": "restricted",
      "Objective": "调用允许的工具取得完成当前任务所需的事实或执行结果。",
      "InsufficiencyPolicy": "如果允许工具不足以完成任务，只调用工具发现能力或停止并说明阻塞，不要编造工具名。",
      "AllowedTools": [
        {
          "Source": "PreferredLoadedOrLoaded"
        }
      ],
      "ForbiddenOutputs": [
        "final_answer",
        "unregistered_tools"
      ],
      "VisibleOutput": {
        "Audience": "runtime",
        "Start": "tool_call_xml_root",
        "Format": "tool_call_xml",
        "Rules": [
          {
            "Name": "natural_language",
            "Value": "forbidden",
            "Instruction": "不要输出解释、寒暄、标题或 Markdown。"
          },
          {
            "Name": "root",
            "Value": "tool_call_xml_root",
            "Instruction": "第一个非空字符必须是 <，并且只输出一个完整工具调用根。"
          },
          {
            "Name": "tool_name_source",
            "Value": "allowed_tools",
            "Instruction": "工具名只能来自 allowed_tools。"
          }
        ],
        "Repair": {
          "Instruction": "只输出完整工具调用 XML；不要解释，不要确认修复，不要回答用户。",
          "Rules": [
            {
              "Name": "start",
              "Value": "tool_call_xml_root",
              "Instruction": "第一个非空字符必须是 <。"
            },
            {
              "Name": "natural_language",
              "Value": "forbidden",
              "Instruction": "XML 外不能有自然语言、Markdown、标题、代码围栏或解释。"
            }
          ]
        }
      },
      "IncludeDecisionProtocol": true,
      "IncludeToolCatalog": true
    }
  ]
}
