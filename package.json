{
  "name": "senera",
  "version": "1.0.0",
  "description": "Observable, verifiable agent runtime and desktop workbench.",
  "workspaces": [
    "Packages/*",
    "Frontend",
    "System/Plugins/*",
    "Plugins/*"
  ],
  "main": "Dist/Source/AgentSystem/AgentSystemRuntime.js",
  "exports": {
    ".": {
      "types": "./Source/AgentSystem/AgentSystemRuntime.ts",
      "import": "./Dist/Source/AgentSystem/AgentSystemRuntime.js",
      "default": "./Dist/Source/AgentSystem/AgentSystemRuntime.js"
    },
    "./plugin-sdk": {
      "types": "./Source/AgentSystem/AgentToolPluginSdk.ts",
      "import": "./Dist/Source/AgentSystem/AgentToolPluginSdk.js",
      "default": "./Dist/Source/AgentSystem/AgentToolPluginSdk.js"
    }
  },
  "scripts": {
    "clean": "rimraf Dist",
    "bamlcheck": "baml check --from baml_src",
    "bamlgenerate": "baml generate --from baml_src",
    "compileopapolicy": "tsx Build/CompileOpaPolicy.ts",
    "sandboxprepare": "tsx Build/PrepareSandboxRuntime.ts --strict",
    "postinstall": "tsx Build/PrepareSandboxRuntime.ts",
    "securitycheck": "npm audit --audit-level=high",
    "check": "tsc --noEmit",
    "build": "npm run clean && tsc && tsx Build/CopyRuntimeAssets.ts",
    "dev": "concurrently -k -n server,frontend -c blue,green \"npm run serverwatch\" \"npm run frontend\"",
    "dockerup": "docker compose pull && docker compose up -d",
    "dockerdown": "docker compose down",
    "dockerlogs": "docker compose logs -f senera",
    "frontend": "npm --workspace senera-frontend run dev",
    "frontendcheck": "npm --workspace senera-frontend run check",
    "frontendtest": "npm --workspace senera-frontend run test",
    "frontendcoverage": "npm --workspace senera-frontend run coverage",
    "frontendverify": "npm --workspace senera-frontend run verify",
    "server": "npm run build && node Dist/Apps/Server.js",
    "serverwatch": "tsx Apps/ServerWatch.ts",
    "serverwatchdry": "tsx Apps/ServerWatch.ts --dry-run",
    "desktop": "npm run build && npm --workspace senera-frontend run build && electron Dist/Apps/Desktop/Main.js",
    "desktoppack": "tsx Apps/Desktop/PackageDesktop.ts",
    "desktoprestore": "npm rebuild better-sqlite3",
    "verifysuite": "node Dist/Scripts/VerifySuite.js",
    "verifysuites": "node Dist/Scripts/VerifySuite.js --list",
    "verifyworkspace": "npm run build && npm run verifysuite -- workspace",
    "verifycontracts": "npm run build && npm run verifysuite -- contracts",
    "verify": "npm run build && npm run verifysuite -- core",
    "verifyall": "npm run build && npm run verifysuite -- all-local",
    "ci": "npm run securitycheck && npm run bamlcheck && npm run check && npm run build && npm run verifysuite -- workspace core && npm run frontendverify && npm run frontendcoverage",
    "test": "npm run check && npm run verify"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "module",
  "build": {
    "appId": "ai.senera.desktop",
    "productName": "Senera",
    "icon": "Apps/Desktop/Assets/senera-icon",
    "publish": null,
    "directories": {
      "output": "Release"
    },
    "files": [
      "Dist/**/*",
      "Frontend/dist/**/*",
      "Apps/Desktop/Assets/**/*",
      "SandboxBundles/**/*",
      "System/Plugins/**/*",
      "Plugins/**/*",
      {
        "from": "Packages/ToolPluginSdk",
        "to": "node_modules/@senera/tool-plugin-sdk",
        "filter": [
          "**/*"
        ]
      },
      "senera.config.example.json",
      "package.json"
    ],
    "extraMetadata": {
      "main": "Dist/Apps/Desktop/Main.js"
    },
    "asarUnpack": [
      "senera.config.example.json",
      "SandboxBundles/**",
      "System/Plugins/**",
      "Plugins/**",
      "**/*.node",
      "**/*.dll",
      "**/*.so",
      "**/*.dylib",
      "**/ffi-rs/**",
      "**/better-sqlite3/**",
      "**/@node-rs/**"
    ],
    "win": {
      "icon": "Apps/Desktop/Assets/senera-icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Senera",
      "artifactName": "SeneraSetup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@ai-sdk/policy-opa": "^1.0.15",
    "@boundaryml/baml": "^0.222.0",
    "@earendil-works/pi-agent-core": "^0.74.2",
    "@earendil-works/pi-ai": "^0.74.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-filesystem": "^2026.7.4",
    "@node-rs/jieba": "^2.0.1",
    "@open-policy-agent/opa-wasm": "^1.10.0",
    "@senera/tool-plugin-sdk": "file:Packages/ToolPluginSdk",
    "@types/better-sqlite3": "^7.6.13",
    "@types/busboy": "^1.5.4",
    "@types/diff": "^7.0.2",
    "@types/mime-types": "^3.0.1",
    "@types/yauzl": "^3.4.0",
    "@vscode/ripgrep": "^1.18.0",
    "@xmldom/xmldom": "^0.9.10",
    "ai": "^7.0.15",
    "ai-sdk-guardrails": "^6.0.1",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.10.0",
    "busboy": "^1.6.0",
    "chalk": "^4.1.2",
    "chardet": "^2.1.1",
    "cross-spawn": "^7.0.6",
    "diff": "^9.0.0",
    "entities": "^8.0.0",
    "eventsource-parser": "^3.0.8",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^5.7.3",
    "file-type": "^22.0.1",
    "gpt-tokenizer": "^3.4.0",
    "iconv-lite": "^0.7.2",
    "ignore": "^7.0.5",
    "istextorbinary": "^9.5.0",
    "json-parse-even-better-errors": "^5.0.0",
    "json-source-map": "^0.6.1",
    "liquidjs": "^10.25.7",
    "markdown-it": "^14.1.1",
    "microsandbox": "^0.6.4",
    "mime-types": "^3.0.2",
    "minisearch": "^7.2.0",
    "officeparser": "^7.2.1",
    "parse5": "^8.0.1",
    "saxes": "^6.0.0",
    "smol-toml": "^1.6.1",
    "tree-kill": "^1.2.2",
    "ts-json-schema-generator": "^2.9.0",
    "tslib": "2.8.1",
    "ws": "^8.20.0",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
