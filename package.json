{
  "name": "senera",
  "version": "1.8.3",
  "description": "Observable, verifiable agent runtime and desktop workbench.",
  "workspaces": [
    "Packages/*",
    "Frontend",
    "System/Plugins/*",
    "Plugins/*"
  ],
  "main": "Dist/Source/AgentSystem/AgentSystemRuntime.js",
  "exports": {
    ".": {
      "types": "./Source/AgentSystem/AgentSystemRuntime.ts",
      "import": "./Dist/Source/AgentSystem/AgentSystemRuntime.js",
      "default": "./Dist/Source/AgentSystem/AgentSystemRuntime.js"
    }
  },
  "scripts": {
    "clean": "rimraf Dist",
    "quality.baml": "baml check --from baml_src",
    "quality.baml.generate": "baml generate --from baml_src",
    "quality.security": "npm audit --audit-level=high",
    "quality.coverage": "npm run test.coverage.frontend && npm run test.coverage.backend",
    "quality.lint": "eslint . --cache --cache-location .cache/eslint/.eslintcache --max-warnings=0",
    "quality.lint.fix": "npm run quality.lint -- --fix",
    "quality.commits": "commitlint",
    "quality.format": "tsx Scripts/VerifyChangedFormatting.ts",
    "quality.format.fix": "tsx Scripts/VerifyChangedFormatting.ts --write",
    "quality.format.full": "prettier \"**/*\" --check --ignore-unknown",
    "quality.format.full.fix": "prettier \"**/*\" --write --ignore-unknown",
    "policy.compile": "tsx Build/CompileOpaPolicy.ts",
    "policy.verify": "tsx Build/CompileOpaPolicy.ts --check",
    "generate.frontend-events": "tsx Build/GenerateFrontendEventCatalog.ts",
    "generate.database-contracts": "tsx Build/GenerateDatabaseContracts.ts",
    "generate.config-command-contracts": "tsx Build/GenerateConfigCommandContracts.ts",
    "generate.protocol-reference": "tsx Build/GenerateWebSocketProtocolReference.ts",
    "generate.tool-contracts": "tsx Build/GenerateToolContractBundles.ts",
    "generate.plugin-config": "tsx Build/GeneratePluginConfigurationArtifacts.ts",
    "verify.tool-contracts": "tsx Build/GenerateToolContractBundles.ts --check",
    "verify.plugin-config": "tsx Build/GeneratePluginConfigurationArtifacts.ts --check",
    "verify.database-contracts": "tsx Build/GenerateDatabaseContracts.ts --check",
    "verify.config-command-contracts": "tsx Build/GenerateConfigCommandContracts.ts --check",
    "access.admin": "tsx Apps/AdminAccess.ts",
    "maintenance.pi-sessions": "tsx Apps/PiSessionMaintenance.ts",
    "maintenance.pi-sessions.apply": "tsx Apps/PiSessionMaintenance.ts --apply",
    "maintenance.pi-sessions.json": "tsx Apps/PiSessionMaintenance.ts --output=json",
    "maintenance.artifacts": "tsx Apps/ArtifactMaintenance.ts",
    "maintenance.artifacts.apply": "tsx Apps/ArtifactMaintenance.ts --apply",
    "maintenance.artifacts.json": "tsx Apps/ArtifactMaintenance.ts --output=json",
    "benchmark.pi-planner": "tsx Apps/PiPlannerBenchmark.ts",
    "benchmark.tool-search": "tsx Apps/ToolSearchBenchmark.ts",
    "terminal.prepare": "tsx Build/PrepareTerminalSidecarGuestRuntime.ts",
    "sandbox.prepare": "tsx Build/PrepareSandboxRuntime.ts",
    "sandbox.archive": "tsx Build/BuildSandboxImageArchive.ts",
    "verify.sandbox.real": "npm run build && npm run sandbox.prepare && tsx Scripts/VerifySeneraMicrosandboxRealTerminal.ts",
    "check.types": "tsc --noEmit",
    "build": "npm run verify.config-command-contracts && npm run verify.database-contracts && npm run verify.plugin-config && npm run verify.tool-contracts && npm run clean && tsc && tsx Build/CopyRuntimeAssets.ts && node Dist/Scripts/VerifyPluginRuntimeManifest.js",
    "dev": "concurrently -k -n server,frontend -c blue,green \"npm run dev.server\" \"npm run dev.frontend\"",
    "docker.up": "docker compose pull && docker compose up -d",
    "docker.down": "docker compose down",
    "docker.logs": "docker compose logs -f senera",
    "dev.frontend": "npm --workspace senera-frontend run dev",
    "check.frontend-types": "npm --workspace senera-frontend run check.types",
    "test.frontend": "npm --workspace senera-frontend run test",
    "test.coverage.frontend": "npm --workspace senera-frontend run test.coverage",
    "test.backend": "vitest run --config vitest.backend.config.ts",
    "test.coverage.backend": "vitest run --config vitest.backend.config.ts --coverage",
    "test.e2e": "vitest run --config vitest.e2e.config.ts",
    "test.all": "npm test && npm run test.e2e",
    "server": "npm run build && node Dist/Apps/Server.js",
    "dev.server": "tsx Apps/ServerWatch.ts",
    "dev.server.dry-run": "tsx Apps/ServerWatch.ts --dry-run",
    "desktop": "npm run build && npm --workspace senera-frontend run build && electron Dist/Apps/Desktop/Main.js",
    "desktop.prepare-native": "tsx Build/PrepareElectronNativeModules.ts",
    "desktop.pack": "tsx Apps/Desktop/PackageDesktop.ts",
    "verify.suite": "node Dist/Scripts/VerifySuite.js",
    "verify.suites": "node Dist/Scripts/VerifySuite.js --list",
    "verify.workspace": "npm run build && npm run verify.suite -- workspace",
    "verify.contracts": "npm run build && npm run verify.suite -- contracts",
    "verify.core": "npm run build && npm run verify.suite -- core",
    "verify.platform": "npm run build && npm run verify.suite -- platform",
    "verify.release": "npm run build && npm run verify.suite -- release",
    "verify.all": "npm run build && npm run verify.suite -- all-local",
    "ci": "npm run quality.security && npm run quality.baml && npm run policy.verify && npm run check.types && npm run quality.lint && npm run quality.format && npm run test.backend && npm run test.frontend && npm run test.e2e && npm run build && npm run verify.suite -- workspace core e2e platform release && npm run quality.coverage",
    "test": "npm run check.types && npm run test.backend && npm run test.frontend",
    "desktop.live": "tsx Apps/Desktop/RunDesktopLive.ts",
    "desktoplive": "npm run desktop.live",
    "desktop.verify": "npm run build && npm --workspace senera-frontend run build",
    "desktopverify": "npm run desktop.verify",
    "desktoppack": "npm run desktop.pack"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "module",
  "build": {
    "appId": "ai.senera.desktop",
    "productName": "Senera",
    "icon": "Apps/Desktop/Assets/senera-icon",
    "publish": null,
    "npmRebuild": false,
    "afterPack": "Build/ElectronAfterPack.cjs",
    "directories": {
      "output": "Release"
    },
    "files": [
      "Dist/**/*",
      "Frontend/dist/**/*",
      "Apps/Desktop/Assets/**/*",
      "System/Plugins/**/*",
      "Plugins/**/*",
      {
        "from": "Packages/ToolPluginSdk",
        "to": "node_modules/@senera/tool-plugin-sdk",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "Packages/TerminalSidecar",
        "to": "node_modules/@senera/terminal-sidecar",
        "filter": [
          "**/*"
        ]
      },
      "senera.config.example.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".senera/sandbox-runtime/terminal-sidecar",
        "to": "TerminalSidecarRuntime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "Dist/Apps/Desktop/Main.js"
    },
    "asarUnpack": [
      "Dist/Apps/Desktop/DesktopMicrosandboxRuntimeBridge.js",
      "node_modules/microsandbox/**/*",
      "node_modules/@superradcompany/microsandbox-*/**/*",
      "senera.config.example.json",
      "System/Plugins/**",
      "Plugins/**",
      "**/*.node",
      "**/*.dll",
      "**/*.so",
      "**/*.dylib",
      "**/ffi-rs/**",
      "**/better-sqlite3/**",
      "**/@node-rs/**"
    ],
    "win": {
      "icon": "Apps/Desktop/Assets/senera-icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Senera",
      "artifactName": "SeneraSetup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@ai-sdk/policy-opa": "^1.0.15",
    "@boundaryml/baml": "^0.222.0",
    "@earendil-works/pi-agent-core": "^0.74.2",
    "@earendil-works/pi-ai": "^0.74.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-filesystem": "^2026.7.4",
    "@node-rs/jieba": "^2.0.1",
    "@open-policy-agent/opa-wasm": "^1.10.0",
    "@senera/terminal-sidecar": "^0.1.0",
    "@senera/tool-plugin-sdk": "file:Packages/ToolPluginSdk",
    "@types/better-sqlite3": "^7.6.13",
    "@types/busboy": "^1.5.4",
    "@types/diff": "^7.0.2",
    "@types/mime-types": "^3.0.1",
    "@types/yauzl": "^3.4.0",
    "@vscode/ripgrep": "^1.18.0",
    "@xmldom/xmldom": "^0.9.10",
    "ai": "^7.0.15",
    "ai-sdk-guardrails": "^6.0.1",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.10.0",
    "busboy": "^1.6.0",
    "chalk": "^4.1.2",
    "chardet": "^2.1.1",
    "cross-spawn": "^7.0.6",
    "diff": "^9.0.0",
    "entities": "^8.0.0",
    "eventsource-parser": "^3.0.8",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^5.7.3",
    "file-type": "^22.0.1",
    "gpt-tokenizer": "^3.4.0",
    "iconv-lite": "^0.7.2",
    "ignore": "^7.0.5",
    "istextorbinary": "^9.5.0",
    "json-parse-even-better-errors": "^5.0.0",
    "json-source-map": "^0.6.1",
    "liquidjs": "^10.25.7",
    "markdown-it": "^14.1.1",
    "microsandbox": "0.6.4",
    "mime-types": "^3.0.2",
    "minisearch": "^7.2.0",
    "officeparser": "^7.2.1",
    "parse5": "^8.0.1",
    "saxes": "^6.0.0",
    "smol-toml": "^1.6.1",
    "tree-kill": "^1.2.2",
    "tslib": "2.8.1",
    "ws": "^8.20.0",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@ladle/react": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.4",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "prettier": "^3.9.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.1.3",
    "semver": "^7.8.5",
    "tailwindcss": "^3.4.17",
    "ts-json-schema-generator": "^2.9.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "js-yaml": "4.3.0",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.16"
    },
    "minimatch@5.1.9": {
      "brace-expansion": "2.1.2"
    },
    "minimatch@9.0.9": {
      "brace-expansion": "2.1.2"
    },
    "minimatch@10.2.5": {
      "brace-expansion": "5.0.7"
    },
    "tar": "7.5.20"
  },
  "optionalDependencies": {
    "@boundaryml/baml-darwin-arm64": "^0.222.0",
    "@boundaryml/baml-darwin-x64": "^0.222.0",
    "@boundaryml/baml-linux-arm64-gnu": "^0.222.0",
    "@boundaryml/baml-linux-arm64-musl": "^0.222.0",
    "@boundaryml/baml-linux-x64-gnu": "^0.222.0",
    "@boundaryml/baml-linux-x64-musl": "^0.222.0",
    "@boundaryml/baml-win32-arm64-msvc": "^0.222.0",
    "@boundaryml/baml-win32-x64-msvc": "^0.222.0",
    "@node-rs/jieba-android-arm-eabi": "^2.0.1",
    "@node-rs/jieba-android-arm64": "^2.0.1",
    "@node-rs/jieba-darwin-arm64": "^2.0.1",
    "@node-rs/jieba-darwin-x64": "^2.0.1",
    "@node-rs/jieba-freebsd-x64": "^2.0.1",
    "@node-rs/jieba-linux-arm-gnueabihf": "^2.0.1",
    "@node-rs/jieba-linux-arm64-gnu": "^2.0.1",
    "@node-rs/jieba-linux-arm64-musl": "^2.0.1",
    "@node-rs/jieba-linux-x64-gnu": "^2.0.1",
    "@node-rs/jieba-linux-x64-musl": "^2.0.1",
    "@node-rs/jieba-wasm32-wasi": "^2.0.1",
    "@node-rs/jieba-win32-arm64-msvc": "^2.0.1",
    "@node-rs/jieba-win32-ia32-msvc": "^2.0.1",
    "@node-rs/jieba-win32-x64-msvc": "^2.0.1"
  }
}
