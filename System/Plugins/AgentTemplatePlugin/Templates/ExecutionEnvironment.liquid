<execution_environment>
  <os>{{ ExecutionEnvironment.os | escape }}</os>
  <platform>{{ ExecutionEnvironment.platform | escape }}</platform>
  <workspace>
    <root>{{ ExecutionEnvironment.workspace.root | escape }}</root>
    <path_style>{{ ExecutionEnvironment.workspace.pathStyle | escape }}</path_style>
    <separator>{{ ExecutionEnvironment.workspace.separator | escape }}</separator>
    <preferred_path_form>{{ ExecutionEnvironment.workspace.preferredPathForm | escape }}</preferred_path_form>
  </workspace>
  <shell>
    <family>{{ ExecutionEnvironment.shell.family | escape }}</family>
    <command>{{ ExecutionEnvironment.shell.command | escape }}</command>
    <invocation>{{ ExecutionEnvironment.shell.invocation | escape }}</invocation>
  </shell>
  <execution_targets>
    <sandbox_preferred>
      <boundary>{{ ExecutionEnvironment.executionTargets.sandboxPreferred.boundary | escape }}</boundary>
      <os>{{ ExecutionEnvironment.executionTargets.sandboxPreferred.os | escape }}</os>
      <image>{{ ExecutionEnvironment.executionTargets.sandboxPreferred.image | escape }}</image>
      <shell_dialect>{{ ExecutionEnvironment.executionTargets.sandboxPreferred.shellDialect | escape }}</shell_dialect>
      <shell_command>{{ ExecutionEnvironment.executionTargets.sandboxPreferred.shellCommand | escape }}</shell_command>
    </sandbox_preferred>
    <local>
      <boundary>{{ ExecutionEnvironment.executionTargets.local.boundary | escape }}</boundary>
      <os>{{ ExecutionEnvironment.executionTargets.local.os | escape }}</os>
      <shell_dialect>{{ ExecutionEnvironment.executionTargets.local.shellDialect | escape }}</shell_dialect>
      <shell_command>{{ ExecutionEnvironment.executionTargets.local.shellCommand | escape }}</shell_command>
    </local>
  </execution_targets>
  <guidance>
{% for rule in ExecutionEnvironment.guidance.shell %}
    <rule>{{ rule | escape }}</rule>
{% endfor %}
{% for rule in ExecutionEnvironment.guidance.paths %}
    <rule>{{ rule | escape }}</rule>
{% endfor %}
  </guidance>
</execution_environment>
