<runtime_tools>
  <rules>
    <rule>本节只描述运行时可用工具；真实工具调用由 Pi Harness 的 custom tools 管理。</rule>
    <rule>需要工具时，选择 allowed_tools 内的工具并提供符合参数契约的 JSON 对象。</rule>
    <rule>不要伪造工具结果；工具返回前不要把推测结果写成事实。</rule>
{% if ToolDiscoveryToolName %}
    <rule>如果当前工具目录没有你需要的能力，先使用 {{ ToolDiscoveryToolName | escape }} 搜索工具目录；不要猜测未展示的工具名。</rule>
{% endif %}
  </rules>

  <tools>
{% for tool in ToolCards %}
    <tool>
      <name>{{ tool.name | escape }}</name>
      <summary>{{ tool.description | escape }}</summary>
      <use_when>{{ tool.whenToUse | escape }}</use_when>
      <avoid_when>{{ tool.whenNotToUse | escape }}</avoid_when>
{% if tool.argumentsContract %}
      <arguments_contract>
        <ts_like_preview>
{% for line in tool.argumentsContract.tsHintLines %}
          <line>{{ line | escape }}</line>
{% endfor %}
        </ts_like_preview>
        <fields>
{% include "ContractFieldTree.liquid", Properties: tool.argumentsContract.properties %}
        </fields>
      </arguments_contract>
{% endif %}
      <documentation>
{{ tool.documentationXml }}
      </documentation>
    </tool>
{% endfor %}
  </tools>
</runtime_tools>
