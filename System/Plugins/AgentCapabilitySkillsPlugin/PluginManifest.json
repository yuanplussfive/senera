{
  "ManifestVersion": 2,
  "Plugin": {
    "Name": "AgentCapabilitySkillsPlugin",
    "Title": "能力技能",
    "Version": "0.1.0",
    "Kind": "Skill",
    "Description": "提供面向模型的任务组织技能，指导复杂任务的检索、取证、验证和输出。"
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 45
  },
  "Templates": [
    {
      "Name": "TddExecution",
      "Path": "./templates/TddExecution.md",
      "Description": "把实现类任务组织成测试优先、实现、验证、收口的执行模板。",
      "ExposeToPi": true,
      "Search": {
        "Summary": "代码修改、缺陷修复、重构、实现功能、验证测试和确定性检查时，指导 Pi 按测试优先、最小实现、运行验证、说明证据的闭环执行。",
        "UseCases": [
          "用户要求修改代码、修复 bug、重构模块、优化实现或落地功能。",
          "任务需要运行测试、类型检查、构建、verify suite 或其他确定性验证。",
          "涉及真实文件变更，需要说明已完成的变更和验证结果。"
        ],
        "Capabilities": [
          {
            "Id": "template.tdd-execution",
            "Title": "TDD style execution",
            "Description": "Apply a test-first or verification-first implementation loop for code-changing work.",
            "Facets": {
              "Actions": ["implement", "fix", "refactor", "verify", "test"],
              "Targets": ["source-code", "frontend", "backend", "plugin", "runtime"],
              "Inputs": ["user-request", "task-frame", "root-command", "workspace-evidence"],
              "Outputs": ["code-change", "test-result", "verification-summary"],
              "Evidence": ["test-output", "type-check", "build-output", "workspace-read"],
              "Effects": ["file-write", "workspace-change"]
            },
            "Aliases": ["测试优先", "实现验证闭环", "代码修改验证", "until done"],
            "Risk": {
              "SideEffect": "workspace-change",
              "Permission": "write"
            },
            "Metadata": {
              "PiResourceKind": "tdd-workflow",
              "PiWorkflowRole": "verification-loop"
            }
          }
        ],
        "Tags": ["代码实现", "测试验证", "重构", "修复", "落地"],
        "Avoid": ["纯解释、闲聊、无需文件变更或无需确定性验证的回答。"]
      }
    },
    {
      "Name": "TodoWorkflow",
      "Path": "./templates/TodoWorkflow.md",
      "Description": "把多步骤任务组织成 Pi 内部 todo、执行、更新、收口的工作流模板。",
      "ExposeToPi": true,
      "Search": {
        "Summary": "复杂任务、持续推进、直到完成、多步骤落地、排查和实现时，指导 Pi 在内部维护 todo 清单并按证据收口。",
        "UseCases": [
          "用户要求继续优化、全面拓展、一步步完成或直到 done。",
          "任务需要跨多个文件、多个工具调用或多个验证步骤。",
          "需要明确完成、阻塞和剩余范围，避免每一步都生成最终回复。"
        ],
        "Capabilities": [
          {
            "Id": "template.todo-workflow",
            "Title": "Pi todo workflow",
            "Description": "Guide Pi to maintain an internal task checklist and complete multi-step work without a parallel Senera goal planner.",
            "Facets": {
              "Actions": ["plan", "execute", "track", "verify", "complete"],
              "Targets": ["multi-step-task", "workflow", "todo", "agent-loop", "implementation"],
              "Inputs": ["user-request", "root-command", "tool-evidence", "session-context"],
              "Outputs": ["completed-work", "verification-summary", "blocked-items"],
              "Evidence": ["tool-result", "workspace-read", "test-output"],
              "Effects": ["internal-planning", "tool-loop"]
            },
            "Aliases": ["todo", "任务清单", "继续直到完成", "until done", "workflow"],
            "Risk": {
              "SideEffect": "internal-planning",
              "Permission": "internal"
            },
            "Metadata": {
              "PiResourceKind": "todo-workflow",
              "PiWorkflowRole": "task-tracking"
            }
          }
        ],
        "Tags": ["todo", "工作流", "复杂任务", "持续执行", "收口"],
        "Avoid": ["简单一次性回答、无需工具、无需多步骤跟踪时不要使用。"]
      }
    },
    {
      "Name": "ImplementationWorkflow",
      "Path": "./templates/ImplementationWorkflow.md",
      "Description": "面向代码库变更的 Pi-native 实现、集成和验证工作流模板。",
      "ExposeToPi": true,
      "Search": {
        "Summary": "代码实现、架构优化、插件适配、运行时集成、产品化落地时，约束 Pi 先读代码、复用抽象、再编辑验证。",
        "UseCases": [
          "用户要求优化拓展、提高代码质量、去硬编码、重构或落地架构。",
          "任务需要修改源码、插件 manifest、前端协议、运行时服务或验证脚本。",
          "需要把能力接到 Pi resources/skills/tools，而不是新建 Senera 自有规划层。"
        ],
        "Capabilities": [
          {
            "Id": "template.implementation-workflow",
            "Title": "Pi implementation workflow",
            "Description": "Guide Pi through code investigation, scoped edits, runtime integration, and verification.",
            "Facets": {
              "Actions": ["implement", "integrate", "refactor", "optimize", "verify"],
              "Targets": ["source-code", "runtime", "plugin", "frontend-protocol", "pi-resource"],
              "Inputs": ["workspace-evidence", "manifest-metadata", "typed-contract", "user-request"],
              "Outputs": ["code-change", "resource-adaptation", "verification-result"],
              "Evidence": ["workspace-read", "type-check", "verify-suite", "build-output"],
              "Effects": ["workspace-change", "runtime-contract-change"]
            },
            "Aliases": ["优化拓展", "代码质量", "去硬编码", "Pi native", "产品化落地"],
            "Risk": {
              "SideEffect": "workspace-change",
              "Permission": "write"
            },
            "Metadata": {
              "PiResourceKind": "implementation-workflow",
              "PiWorkflowRole": "code-integration"
            }
          }
        ],
        "Tags": ["实现", "集成", "重构", "Pi-native", "代码质量"],
        "Avoid": ["纯概念解释、无需修改代码或无需运行验证时不要使用。"]
      }
    }
  ],
  "Skills": [
    {
      "Name": "ExecutionWorkflowSkill",
      "Title": "执行工作流",
      "DescriptionFile": "./docs/ExecutionWorkflow.md",
      "RecommendedTools": [
        "WorkspaceGrep",
        "WorkspaceReadFile",
        "WorkspaceSearchFiles",
        "WorkspaceApplyPatch",
        "ShellCommandTool"
      ],
      "Search": {
        "Summary": "复杂任务、继续优化、全面落地、todo、workflow、TDD、until done 和 Pi-native 执行时，保持任务跟踪、工具证据和验证闭环。",
        "Capabilities": [
          {
            "Id": "skill.execution-workflow",
            "Title": "Pi execution workflow",
            "Description": "Keep multi-step work inside Pi resources and tool loops with task tracking and verification.",
            "Facets": {
              "Actions": ["plan", "execute", "implement", "verify", "complete"],
              "Targets": ["workflow", "todo", "tdd", "pi-resource", "runtime"],
              "Inputs": ["user-request", "root-command", "workspace-evidence"],
              "Outputs": ["completed-work", "verification-summary"],
              "Evidence": ["tool-result", "test-output", "build-output"],
              "Effects": ["internal-planning", "workspace-change"]
            },
            "Aliases": ["继续优化", "全面落地", "不要硬编码", "workflow", "todo", "TDD", "until done"],
            "Risk": {
              "SideEffect": "workspace-change",
              "Permission": "write"
            }
          }
        ],
        "UseCases": [
          "用户要求继续全面优化拓展、提高代码质量、去硬编码并验证。",
          "任务需要跨多个步骤推进，而不是一次性回答。"
        ],
        "Tags": ["执行工作流", "todo", "TDD", "Pi-native", "持续落地"],
        "Avoid": ["单步说明、闲聊或无需工具闭环的回答。"]
      },
      "EvidenceRequirements": [
        {
          "Need": "completed work verification",
          "Accepts": ["test output", "type check", "build output", "workspace evidence"],
          "MinimumQuality": ["observed"],
          "Minimum": 1,
          "Purpose": "复杂落地任务需要用实际工具结果或源码读取证明进度与完成状态。"
        }
      ]
    },
    {
      "Name": "WorkspaceInvestigationSkill",
      "Title": "工作区调查",
      "DescriptionFile": "./docs/WorkspaceInvestigation.md",
      "RecommendedTools": [
        "WorkspaceListDirectory",
        "WorkspaceSearchFiles",
        "WorkspaceGrep",
        "WorkspaceListFiles",
        "WorkspaceReadFile",
        "ShellCommandTool"
      ],
      "Search": {
        "Summary": "定位代码、配置、提示词、UI 文案、错误处理或跨文件实现时，按搜索、读取、再搜索、取证的闭环工作。",
        "Capabilities": [
          {
            "Id": "skill.workspace-investigation",
            "Title": "Workspace investigation",
            "Description": "Guide local code investigation through search, candidate reading, query refinement, and evidence-backed conclusions.",
            "Facets": {
              "Actions": ["investigate", "search", "read", "verify"],
              "Targets": ["workspace", "source-code", "configuration", "prompt-template", "ui-code"],
              "Inputs": ["natural-language", "identifier", "path", "error-text", "ui-description"],
              "Outputs": ["source-location", "evidence-backed-summary", "next-edit-target"],
              "Evidence": ["workspace-search-match", "workspace-read"],
              "Effects": ["read-only", "index-cache"]
            },
            "Aliases": ["代码调查", "搜索读取闭环", "find code and verify", "search read refine"],
            "Risk": {
              "SideEffect": "index-cache",
              "Permission": "read"
            }
          }
        ],
        "UseCases": [
          "本地功能、错误、UI、配置、提示词实现调查。",
          "项目用途、代码库入口、主要模块、README、package、配置证据读取。",
          "搜索候选、读取文件、继续追踪、证据支持结论。"
        ],
        "Examples": [
          "插件工作区索引实现",
          "停止按钮执行取消逻辑",
          "planner 上下文构建",
          "项目用途 README package",
          "代码库入口模块"
        ],
        "Avoid": ["无需本地工作区事实的闲聊、解释或纯设计讨论。"],
        "Tags": ["项目调查", "代码理解", "工作区检索", "文件阅读", "问题定位"]
      },
      "EvidenceRequirements": [
        {
          "Need": "workspace read source-of-truth evidence",
          "Accepts": [
            "workspace read",
            "project identity",
            "project purpose",
            "implementation detail",
            "source behavior"
          ],
          "MinimumQuality": ["observed"],
          "Minimum": 1,
          "Purpose": "本地工作区结论需要来自已读取的文件、目录读取或源码片段；项目地图和搜索候选只用于定位，不满足最终回答。"
        }
      ]
    },
