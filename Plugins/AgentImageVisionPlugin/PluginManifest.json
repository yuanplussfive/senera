{
  "ManifestVersion": 2,
  "Contracts": { "File": "./ToolContracts.json" },
  "Plugin": {
    "Name": "AgentImageVisionPlugin",
    "Title": "图片识别",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Description": "按 uploadUri 读取用户上传图片，并通过插件配置的视觉模型进行识别、OCR 或问答。"
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 8
  },
  "Tools": [
    {
      "Name": "ImageVisionTool",
      "Loading": "Dynamic",
      "DescriptionFile": "./docs/Tool.md",
      "Permissions": ["filesystem:read:uploads", "network:model-provider"],
      "Handler": {
        "Kind": "HostCapability",
        "Capability": "image.vision"
      },
      "Execution": {
        "Boundary": "Local",
        "Network": "Allow",
        "Workspace": "ReadOnly",
        "LocalFallback": "Deny"
      },
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "image_vision_result",
            "Records": "$.images.item[*]",
            "Slots": {
              "uploadUri": "$.uploadUri",
              "status": "$.status",
              "task": "$.task",
              "question": "$.question",
              "name": "$.name",
              "mime": "$.mime",
              "size": "$.size",
              "answer": "$.answer",
              "providerId": "$.providerId",
              "providerEndpoint": "$.providerEndpoint",
              "providerModel": "$.providerModel",
              "message": "$.message"
            },
            "Identity": {
              "Parts": [
                "uploadUri",
                "task",
                {
                  "Slot": "question",
                  "Required": false
                }
              ]
            },
            "Presentation": {
              "Locator": "{{ uploadUri }}",
              "Display": "image vision {{ status }}: {{ name }}",
              "Label": "{{ name }}",
              "Source": "{{ providerModel }}"
            },
            "Confidence": 0.9,
            "Metadata": {
              "status": "$.status",
              "task": "$.task",
              "mime": "$.mime",
              "providerId": "$.providerId",
              "providerModel": "$.providerModel"
            },
            "ModelProjection": {
              "Slots": ["uploadUri", "status", "task", "question", "name", "mime", "answer", "providerModel", "message"]
            },
            "PlannerMemory": {
              "Facts": ["uploadUri", "status", "task", "question", "name", "mime", "providerModel"],
              "ArtifactRefs": ["projection"]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.status }} {{ e.slots.name }} task={{ e.slots.task }}\n  answer: {{ e.slots.answer }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} image vision\n  uri: {{ e.slots.uploadUri }}\n  status: {{ e.slots.status }}\n  task: {{ e.slots.task }}\n  question: {{ e.slots.question }}\n  name: {{ e.slots.name }}\n  mime: {{ e.slots.mime }}\n  provider: {{ e.slots.providerModel }}\n  answer: {{ e.slots.answer }}\n  message: {{ e.slots.message }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}"
        }
      },
      "Search": {
        "Summary": "按 uploadUri 对用户上传图片、截图进行视觉识别、OCR 或问答。",
        "Tags": ["图片理解", "视觉识别", "截图分析", "文字识别", "附件处理"],
        "Capabilities": [
          {
            "Id": "image.vision",
            "Title": "Image vision",
            "Description": "Analyze an uploaded image by resolving uploadUri and routing it to the configured vision model.",
            "Facets": {
              "Actions": ["inspect", "describe", "ocr", "answer"],
              "Targets": ["uploaded-image", "screenshot"],
              "Inputs": ["upload-uri", "question", "task"],
              "Outputs": ["visual-observations", "visible-text", "image-answer"],
              "Evidence": ["image-vision-result"],
              "Effects": ["model-call"]
            },
            "Aliases": ["看图", "识别图片", "读取截图", "image OCR", "answer about this image"],
            "Risk": {
              "SideEffect": "model-call",
              "Permission": "upload-read"
            }
          }
        ],
        "UseCases": ["上传图片视觉描述、OCR、截图错误识别。", "UI 截图结构、文字、异常状态分析。"],
        "Examples": ["上传图片 OCR", "截图错误识别", "界面截图视觉检查", "image upload vision analysis"],
        "Avoid": ["不要对非图片附件直接调用；先探测文件类型。", "不要猜测 uploadUri。"]
      },
      "Runtime": {
        "Lifecycle": "Immediate",
        "ProtocolVersion": 2,
        "Capabilities": {
          "Cancellation": true
        }
      }
    }
  ],
  "Security": {
    "TrustLevel": "External",
    "Network": "Allow",
    "FileSystem": {
      "Read": [".senera/uploads"],
      "Write": []
    },
    "RequiresApproval": false
  }
}
