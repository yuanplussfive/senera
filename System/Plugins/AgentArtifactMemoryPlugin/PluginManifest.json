{
  "Plugin": {
    "Name": "AgentArtifactMemoryPlugin",
    "Title": "Artifact Memory Reader",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Description": "Loads persisted artifact memories by canonical artifact URI."
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 8
  },
  "Tools": [
    {
      "Name": "ArtifactMemoryReadTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [
        "filesystem:read:artifacts"
      ],
      "Handler": {
        "Kind": "HostCapability",
        "Capability": "artifact.memory.read"
      },
      "Execution": {
        "Boundary": "Local",
        "Network": "Deny",
        "Workspace": "ReadOnly",
        "LocalFallback": "Allow"
      },
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "artifact_memory",
            "Records": "$.artifacts.item[*]",
            "Slots": {
              "artifactUri": "$.artifactUri",
              "artifactId": "$.artifactId",
              "status": "$.status",
              "message": "$.message",
              "availableRefCount": "$.availableRefCount",
              "memoryCount": "$.memoryCount"
            },
            "Identity": {
              "Parts": [
                "artifactUri",
                "status"
              ]
            },
            "Presentation": {
              "Locator": "{{ artifactUri }}",
              "Display": "artifact memory {{ status }}: {{ artifactUri }}",
              "Label": "{{ artifactUri }}",
              "Source": "{{ message }}"
            },
            "Confidence": 0.9,
            "Metadata": {
              "status": "$.status",
              "availableRefCount": "$.availableRefCount",
              "memoryCount": "$.memoryCount"
            },
            "ModelProjection": {
              "Slots": [
                "artifactUri",
                "artifactId",
                "status",
                "message",
                "availableRefCount",
                "memoryCount"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "artifactUri",
                "artifactId",
                "status",
                "availableRefCount",
                "memoryCount"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.status }} {{ e.slots.artifactUri }} (loaded {{ e.slots.memoryCount }} refs)\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} artifact memory\n  uri: {{ e.slots.artifactUri }}\n  status: {{ e.slots.status }}\n  availableRefs: {{ e.slots.availableRefCount }}\n  loadedRefs: {{ e.slots.memoryCount }}\n  message: {{ e.slots.message }}\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        }
      },
      "Search": {
        "Summary": "按 artifactUri 读取已经落地的 artifact 记忆和证据投影。",
        "Capabilities": [
          {
            "Id": "artifact.memory-read",
            "Title": "Artifact memory read",
            "Description": "Load persisted artifact projections or evidence records by canonical artifact URI.",
            "Facets": {
              "Actions": [
                "read",
                "hydrate",
                "inspect"
              ],
              "Targets": [
                "artifact-memory",
                "artifact-projection",
                "artifact-evidence"
              ],
              "Inputs": [
                "artifact-uri",
                "artifact-uri-list",
                "artifact-ref"
              ],
              "Outputs": [
                "artifact-memory",
                "projection-text",
                "evidence-json"
              ],
              "Evidence": [
                "artifact-memory"
              ],
              "Effects": [
                "read-only"
              ]
            },
            "Aliases": [
              "读取记忆",
              "展开证据",
              "load artifact memory",
              "hydrate artifact evidence"
            ],
            "Risk": {
              "SideEffect": "read-only",
              "Permission": "artifact-read"
            }
          }
        ],
        "UseCases": [
          "历史工具结果、网页搜索结果、artifact projection、evidence 结构化读取。"
        ],
        "Examples": [
          "senera artifact projection",
          "artifactUri evidence.json",
          "结构化证据读取",
          "projection artifact memory"
        ],
        "Avoid": [
          "artifactUri 缺失时先使用当前上下文或检索工具定位证据引用。",
          "只需要轻量 facts 就能回答时不要读取完整 artifact。"
        ],
        "Tags": [
          "证据读取",
          "产物记忆",
          "上下文恢复",
          "历史资料"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "System",
    "Network": "Deny",
    "FileSystem": {
      "Read": [
        ".senera/artifacts"
      ],
      "Write": []
    },
    "RequiresApproval": false
  }
}
