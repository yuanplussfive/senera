<merge_task name="FindingsBySeverity">
  <goal>Merge child review results into one findings object. Preserve only concrete findings with evidence.</goal>
  <policy>
    <strategy>{{ MergePolicy.strategy | escape }}</strategy>
    <description>{{ MergePolicy.description | default: "" | escape }}</description>
  </policy>
  <workflow>
    <name>{{ Plan.workflow.name | escape }}</name>
    <objective>{{ Plan.objective | default: "" | escape }}</objective>
  </workflow>
  <child_results>
{% for child in ChildResults %}
    <child>
      <job_id>{{ child.jobId | escape }}</job_id>
      <agent>{{ child.agentName | escape }}</agent>
      <status>{{ child.status | escape }}</status>
      <text>
{{ child.text }}
      </text>
    </child>
{% endfor %}
  </child_results>
  <output_schema>
{{ OutputSchema.text }}
  </output_schema>
</merge_task>
