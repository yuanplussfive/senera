{
  "defaultSuite": "core",
  "suites": {
    "workspace": {
      "description": "Root workspace dependency and install-boundary governance.",
      "patterns": ["VerifyWorkspaceDependencyGovernance.js", "VerifyCommitMessagePolicy.js"]
    },
    "contracts": {
      "description": "Static architecture contracts that should fail before runtime tests.",
      "patterns": ["VerifyAgentTypeContractBoundaries.js"]
    },
    "core": {
      "description": "Agent runtime and plugin contracts without browser, E2E, or OS-specific checks.",
      "patterns": [
        "VerifyAgentTypeContractBoundaries.js",
        "VerifyBackendTestCoverage.js",
        "VerifyPluginConfigSchema.js",
        "VerifyRuntimeEventContract.js",
        "VerifyWebSocketProtocolReference.js",
        "VerifyAgentErrorI18n.js",
        "VerifyFrontendErrorI18n.js",
        "VerifyAgentRuntimeI18n.js",
        "VerifyFrontendRuntimeI18n.js",
        "VerifyPluginArtifactPolicies.js",
        "VerifyPluginReferenceValidation.js",
        "VerifyPluginProcessRuntimeManifest.js",
        "VerifyToolExecutionPolicy.js",
        "VerifyWorkspaceApplyPatchTool.js",
        "VerifyPluginProcessBundleProjection.js",
        "VerifyToolSignatureMappingAndPlanValidation.js",
        "VerifyModelProviderEndpointConfig.js",
        "VerifyOpenAiCompatibleMessageProjection.js",
        "VerifyAgentConfigFormProjection.js",
        "VerifyModelTimeoutConfig.js",
        "VerifyVectorModelClient.js",
        "VerifyWorkspaceContextFffSearch.js",
        "VerifyAgentRuntimeServices.js",
        "VerifyMemorySourceIdempotency.js",
        "VerifyPiResourceProjection.js",
        "VerifyPiNativeWorkflowResourceRouting.js",
        "VerifyPiSessionBootstrap.js",
        "VerifyPiSessionManagerBootstrap.js",
        "VerifyPiHarnessSessionReuse.js",
        "VerifyPiRuntimeQueueSteering.js",
        "VerifyPiAgentLoopSubstrate.js",
        "VerifyPiContextPolicy.js",
        "VerifyAgentLoopRuntimeBoundary.js",
        "VerifyPiOpenAiTranscriptProjection.js",
        "VerifyPiTurnExecutorContracts.js",
        "VerifyPiAssistantCompilerController.js",
        "VerifyPiProxyOpenAiWire.js",
        "VerifyPiToolExecutionBridge.js",
        "VerifyMcpPersistentProcessBoundary.js",
        "VerifyAgentSafetyApproval.js",
        "VerifyComplexityBudget.js",
        "VerifyConfigServiceSqliteSource.js"
      ]
    },
    "frontend": {
      "description": "Frontend test governance and UI behavior through Vitest.",
      "patterns": ["VerifyFrontendTestCoverage.js"]
    },
    "e2e": {
      "description": "End-to-end test governance and protocol behavior.",
      "patterns": ["VerifyE2eTestCoverage.js"]
    },
    "platform": {
      "description": "Cross-platform execution, sandbox, and desktop path smoke checks.",
      "patterns": [
        "VerifySeneraExecutionEnvBoundary.js",
        "VerifySeneraMicrosandboxBackend.js",
        "VerifySeneraMicrosandboxRuntimeRetry.js",
        "VerifySeneraSandboxRuntimeService.js",
        "VerifySandboxRuntimeConfig.js",
        "VerifySandboxPrepareRuntime.js",
        "VerifyRuntimeModulePath.js",
        "VerifyDesktopRuntimeConfigProjection.js",
        "VerifyDesktopRuntimeAssetSync.js",
        "VerifyDesktopRuntimePaths.js",
        "VerifyDesktopFrontendSource.js",
        "VerifyDesktopLiveFrontendServer.js"
      ]
    },
    "release": {
      "description": "Container and desktop release metadata and runtime policies.",
      "patterns": ["VerifyDockerRuntimeSandboxPolicy.js", "VerifyProductReleaseInfo.js"]
    },
    "all-local": {
      "description": "Every maintained local verification script except the suite runner.",
      "patterns": ["Verify*.js", "!VerifySuite.js"]
    }
  }
}
