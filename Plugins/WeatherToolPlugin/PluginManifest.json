{
  "Plugin": {
    "Name": "WeatherToolPlugin",
    "Title": "Weather Tool",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Entry": {
      "Kind": "Process",
      "Command": "node",
      "Args": [
        "index.js"
      ],
      "Cwd": "."
    }
  },
  "Discovery": {
    "Tags": [
      "weather",
      "天气",
      "open-meteo",
      "real-world",
      "forecast",
      "预报",
      "温度"
    ]
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 50
  },
  "Tools": [
    {
      "Name": "WeatherTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [
        "network:https://api.open-meteo.com",
        "network:https://geocoding-api.open-meteo.com"
      ],
      "Search": {
        "Summary": "查询指定城市、地址或经纬度的当前天气和天气预报。",
        "Keywords": [
          "weather",
          "forecast",
          "temperature",
          "rain",
          "open-meteo",
          "天气",
          "气温",
          "温度",
          "下雨",
          "预报",
          "城市"
        ],
        "UseCases": [
          "用户询问天气、气温、降雨、城市预报或经纬度天气时使用。"
        ],
        "Examples": [
          "上海今天的天气怎么样",
          "北京明天会下雨吗",
          "weather in New York",
          "查询 31.23 121.47 的天气"
        ],
        "Avoid": [
          "不要用于查询新闻、网页或本地代码。"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "External",
    "Network": "Allow",
    "FileSystem": {
      "Read": [],
      "Write": []
    },
    "RequiresApproval": false
  }
}
