{
  "Plugin": {
    "Name": "AgentPatchToolPlugin",
    "Title": "Apply Patch Tool",
    "Version": "0.1.0",
    "Kind": "Tool"
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 95
  },
  "Tools": [
    {
      "Name": "ApplyPatchTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [
        "filesystem:write:workspace"
      ],
      "Handler": {
        "Kind": "HostCapability",
        "Capability": "patch.apply"
      },
      "Artifacts": {
        "Evidence": [
          {
            "Kind": "workspace_file",
            "Records": "$.changedFiles.item[*]",
            "Slots": {
              "path": "$.path",
              "status": "$.status",
              "additions": "$.additions",
              "deletions": "$.deletions"
            },
            "Identity": {
              "Parts": [
                "path",
                "status"
              ]
            },
            "Presentation": {
              "Locator": "{{ path }}",
              "Display": "workspace file {{ status }}: {{ path }}",
              "Label": "{{ path }}",
              "Source": "{{ status }}"
            },
            "Confidence": 0.95,
            "Metadata": {
              "additions": "$.additions",
              "deletions": "$.deletions",
              "status": "$.status"
            },
            "ModelProjection": {
              "Slots": [
                "path",
                "status",
                "additions",
                "deletions"
              ]
            },
            "PlannerMemory": {
              "Facts": [
                "path",
                "status",
                "additions",
                "deletions"
              ],
              "ArtifactRefs": [
                "evidence",
                "projection",
                "workspaceDiff",
                "workspacePatch"
              ]
            },
            "Projection": {
              "SummaryTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.status }} {{ e.slots.path }}\n{% endfor %}",
              "ArtifactTemplate": "{% for e in evidence %}- evidenceUri: {{ e.evidenceUri }} {{ e.slots.status }} {{ e.slots.path }} (+{{ e.slots.additions }}, -{{ e.slots.deletions }})\n{% endfor %}"
            }
          }
        ],
        "Summary": {
          "Template": "{% for block in projections %}{{ block.summary }}\n{% endfor %}",
          "ArtifactTemplate": "{% for block in projections %}{{ block.artifact }}\n{% endfor %}{% if workspace %}{% for change in workspace.changes %}- {{ change.status }} {{ change.path }}\n{% endfor %}{% endif %}"
        },
        "Workspace": {
          "Capture": "declared",
          "Paths": [
            {
              "Selector": "$.operations.item[*].path",
              "Base": "$.cwd"
            },
            {
              "Selector": "$.changedFiles.item[*].path"
            }
          ],
          "MaxFileBytes": 262144,
          "MaxFiles": 128,
          "MaxDirectoryDepth": 0,
          "CaptureContent": "text",
          "PatchContextLines": 3
        }
      },
      "Search": {
        "Summary": "按结构化编辑操作创建、替换、插入、删除或修改工作区文件。",
        "Capabilities": [
          {
            "Id": "workspace.patch-edit",
            "Title": "Workspace patch edit",
            "Description": "Apply structured file edits, creations, replacements, insertions, and deletions in the workspace.",
            "Facets": {
              "Actions": [
                "edit",
                "patch",
                "create",
                "replace",
                "insert",
                "delete"
              ],
              "Targets": [
                "workspace",
                "file",
                "source-code",
                "configuration",
                "documentation"
              ],
              "Inputs": [
                "path",
                "operation",
                "content",
                "line-range"
              ],
              "Outputs": [
                "workspace-file-change",
                "patch-summary",
                "changed-file"
              ],
              "Evidence": [
                "workspace-file"
              ],
              "Effects": [
                "write-workspace"
              ]
            },
            "Aliases": [
              "编辑文件",
              "应用补丁",
              "modify file",
              "apply patch"
            ],
            "Risk": {
              "SideEffect": "write-workspace",
              "Permission": "write",
              "Notes": [
                "Changes workspace files."
              ]
            }
          }
        ],
        "UseCases": [
          "需要实际修改代码、配置、文档或批量应用文件变更时使用。"
        ],
        "Examples": [
          "AgentToolSearchIndex.ts 修改",
          "PluginManifest.json Search 字段",
          "new config example file",
          "replace lines 20 35"
        ],
        "Avoid": [
          "只想查看文件内容时使用读取工具；只想运行命令时使用 ShellCommandTool。"
        ],
        "Tags": [
          "文件编辑",
          "代码修改",
          "补丁应用",
          "创建删除",
          "工作区写入"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "System",
    "Network": "Deny",
    "FileSystem": {
      "Read": [
        "../.."
      ],
      "Write": [
        "../.."
      ]
    },
    "RequiresApproval": false
  }
}
