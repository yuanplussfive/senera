  "MergePolicies": [
    {
      "Name": "FindingsBySeverity",
      "Description": "将多个审查代理的发现按严重度、证据和文件位置合并。",
      "Strategy": "findings.bySeverity",
      "TemplateFile": "./merges/FindingsBySeverity.liquid",
      "OutputSchema": "./schemas/FindingList.schema.json"
    },
    {
      "Name": "EvidenceSummaryMerge",
      "Description": "合并多个调查代理的证据摘要、未确认点和后续读取建议。",
