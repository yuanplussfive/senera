{% if ActionDirective %}
<senera_action_directive>
  <policy>
    <rule>这是宿主在本轮主推理前生成的执行指令，优先级高于普通上下文。</rule>
    <rule>它不是用户可见内容，不要复述标签名或规划字段。</rule>
    <rule>如果 action 指向工具使用，优先调用 preferred_tools 中已展示的工具。</rule>
  </policy>
  <decision>
    <action>{{ ActionDirective.action | escape }}</action>
{% if ActionDirective.instruction %}
    <instruction>{{ ActionDirective.instruction | escape }}</instruction>
{% endif %}
{% if ActionDirective.preferredTools.size > 0 %}
    <preferred_tools>
{% for tool in ActionDirective.preferredTools %}
      <tool>{{ tool | escape }}</tool>
{% endfor %}
    </preferred_tools>
{% endif %}
{% if ActionDirective.toolSearchQueries.size > 0 %}
    <tool_search_queries>
{% for query in ActionDirective.toolSearchQueries %}
      <query>{{ query | escape }}</query>
{% endfor %}
    </tool_search_queries>
{% endif %}
{% if ActionDirective.needs.size > 0 %}
    <capability_needs>
{% for need in ActionDirective.needs %}
      <need>
{% if need.actions.size > 0 %}
        <actions>{% for item in need.actions %}<item>{{ item | escape }}</item>{% endfor %}</actions>
{% endif %}
{% if need.targets.size > 0 %}
        <targets>{% for item in need.targets %}<item>{{ item | escape }}</item>{% endfor %}</targets>
{% endif %}
{% if need.inputs.size > 0 %}
        <inputs>{% for item in need.inputs %}<item>{{ item | escape }}</item>{% endfor %}</inputs>
{% endif %}
{% if need.outputs.size > 0 %}
        <outputs>{% for item in need.outputs %}<item>{{ item | escape }}</item>{% endfor %}</outputs>
{% endif %}
{% if need.evidence.size > 0 %}
        <evidence>{% for item in need.evidence %}<item>{{ item | escape }}</item>{% endfor %}</evidence>
{% endif %}
{% if need.effects.size > 0 %}
        <effects>{% for item in need.effects %}<item>{{ item | escape }}</item>{% endfor %}</effects>
{% endif %}
      </need>
{% endfor %}
    </capability_needs>
{% endif %}
  </decision>
</senera_action_directive>
{% endif %}
