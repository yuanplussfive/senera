{
  "Plugin": {
    "Name": "TaskPrioritizerToolPlugin",
    "Title": "Task Prioritizer Tool",
    "Version": "0.1.0",
    "Kind": "Tool",
    "Entry": {
      "Kind": "Process",
      "Command": "node",
      "Args": [
        "index.js"
      ],
      "Cwd": "."
    }
  },
  "Discovery": {
    "Tags": [
      "task",
      "任务",
      "planning",
      "计划",
      "priority",
      "local",
      "优先级",
      "排序",
      "待办"
    ]
  },
  "Prompting": {
    "Audience": "Model",
    "Priority": 57
  },
  "Tools": [
    {
      "Name": "TaskPrioritizerTool",
      "DescriptionFile": "./docs/Tool.md",
      "SignatureFile": "./ToolSignature.ts",
      "Permissions": [],
      "Search": {
        "Summary": "根据影响、紧急度、工作量和依赖关系给任务排序。",
        "Keywords": [
          "task",
          "priority",
          "planning",
          "todo",
          "schedule",
          "任务",
          "优先级",
          "排序",
          "计划",
          "待办",
          "排期"
        ],
        "UseCases": [
          "用户给出一组任务，需要规划执行顺序、优先级或聚焦策略时使用。"
        ],
        "Examples": [
          "帮我给这些任务排优先级",
          "这些待办先做哪个",
          "prioritize this task list"
        ],
        "Avoid": [
          "不要用于执行命令、编辑文件或搜索代码。"
        ]
      }
    }
  ],
  "Security": {
    "TrustLevel": "Local",
    "Network": "Deny",
    "FileSystem": {
      "Read": [],
      "Write": []
    },
    "RequiresApproval": false
  }
}
